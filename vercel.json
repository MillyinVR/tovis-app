{
  "buildCommand": "if [ \"$VERCEL_ENV\" = \"production\" ]; then prisma migrate deploy; fi && next build",
  "regions": ["pdx1"],
  "git": {
    "deploymentEnabled": false
  },
  "crons": [
    {
      "path": "/api/internal/jobs/hold-cleanup",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/internal/jobs/stripe-orphan-recovery",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/internal/jobs/stripe-reconciliation",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/internal/jobs/stripe-webhook-requeue",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/internal/jobs/notifications/process",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/internal/jobs/notifications/health",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/internal/jobs/last-minute/process",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/internal/jobs/client-reminders",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/internal/cron/retry-verification-emails",
