    {
      "path": "/api/internal/jobs/migration/calendar-resync",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/internal/jobs/handle-reservations",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/internal/jobs/nfc/tap-intent-cleanup",
      "schedule": "30 9 * * *"
    }
