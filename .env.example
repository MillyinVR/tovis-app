# Tovis environment variables — template
#
# Copy to .env.local for local dev and fill in real values:
#     cp .env.example .env.local
#
# This file is the documented contract of every env var the app reads. Real
# secrets live ONLY in .env.local (gitignored) and in the Vercel project env for
# deployed environments — never commit a real value here.
#
# Production fail-closed contract: a production boot is REJECTED at startup
# (lib/observability/startupEnvValidation.ts) unless the Sentry DSN, an internal
# job/cron secret, and the Postmark email config are all present.
# Values below are placeholders. "(prod-required)" marks vars enforced at boot.

# ─────────────────────────────────────────────────────────────────────────────
# Core app / URLs
# ─────────────────────────────────────────────────────────────────────────────
APP_ENV=development                      # development | staging | production
APP_URL=http://localhost:3000            # server-side absolute base URL
NEXT_PUBLIC_APP_URL=http://localhost:3000 # browser-visible base URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000
LOCAL_APP_URL=http://localhost:3000
APP_ROOT_DOMAIN=localhost                # bare domain for vanity handles (e.g. tovis.me)
NEXT_PUBLIC_BRAND=                       # white-label brand key (blank = default brand)

# ─────────────────────────────────────────────────────────────────────────────
# Database (Postgres / Supabase) — DATABASE_URL is prod-required
# ─────────────────────────────────────────────────────────────────────────────
# Pooled connection used by the app. DIRECT_URL (unpooled) is used by Prisma
# migrate. WARNING: locally these must point at a LOCAL dev DB — set them in
# .env.development.local (loaded above .env.local by Next and prisma.config.ts).
# The local dev DB runs on port 5434 via `pnpm db:dev:up`; see
# docs/local-dev-database.md and the prisma guard (scripts/prisma-guard.cjs).
#
# PRODUCTION (Supabase) pooling — see docs/runbooks/deploy-and-rollback.md:
#  • DATABASE_URL = the POOLER endpoint, and MUST carry an explicit
#    ?connection_limit=N. On serverless each instance opens its own pool; with no
#    limit, fan-out exhausts the pooler's max connections (EMAXCONN). Boot emits a
#    `database_url_no_connection_limit` warning when it's absent.
#  • DIRECT_URL = the DIRECT/session endpoint on port 5432
#    (db.<ref>.supabase.co:5432), NOT the transaction pooler (:6543) — migrate
#    needs a session advisory lock the transaction pooler can't hold. Boot warns
#    (`direct_url_on_transaction_pooler`) if it sees :6543 / pgbouncer=true.
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/tovis_dev
DIRECT_URL=postgresql://postgres:postgres@localhost:5434/tovis_dev
# Optional read-replica URL for hot read paths (discover, availability, public
# profile) via lib/prisma.ts `prismaRead`. Unset → reads fall back to the primary
# client. In prod, point at the Supabase read replica so reads don't consume the
# primary pool's connection budget.
DATABASE_URL_READ=
# Comma-separated host fragments that mark a DATABASE_URL as production; the
# prisma guard refuses destructive commands against any match.
PRODUCTION_DATABASE_HOSTS=
PRISMA_GUARD_ALLOW_PROD=                 # set to 1 ONLY to intentionally override the guard
CONFIRM_NON_PRODUCTION_DB=               # safety ack for destructive dev scripts

# ─────────────────────────────────────────────────────────────────────────────
# Auth / sessions
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string
AUTH_TRUSTED_IP_HEADER=x-forwarded-for   # ingress header that carries the real client IP
APPLE_CLIENT_ID=                         # Sign in with Apple: the iOS app bundle id (= identity-token `aud`), e.g. me.tovis.Tovis
APPLE_WEB_CLIENT_ID=                      # Sign in with Apple (WEB): the Services ID (= web identity-token `aud`), e.g. me.tovis.web. Leave blank to disable Apple-on-web.
NEXT_PUBLIC_APPLE_CLIENT_ID=              # Same Services ID, exposed to the browser for "Sign in with Apple JS". Blank = no Apple button on web.
GOOGLE_CLIENT_ID=                         # Google Sign-In: OAuth 2.0 Web client id (= id-token `aud`). Falls back to NEXT_PUBLIC_GOOGLE_CLIENT_ID.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=            # Same Google OAuth Web client id, exposed to the browser for Google Identity Services. Blank = no Google button on web.
ADMIN_EMAIL=                             # seed/admin bootstrap (dev/seed only)
ADMIN_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# PII encryption keyrings (prod-required for PII features)
# JSON keyrings — generate per environment; rotate via the documented procedure.
# In Vercel these are marked Sensitive and cannot be pulled back (vercel env pull
# returns blank) — see the prod-env memory notes.
# ─────────────────────────────────────────────────────────────────────────────
PII_AEAD_KEYS_JSON=                      # AES-256-GCM keyring for address/notes/phone/email
                                         # (must include an "email-aead-v1" key before the
                                         #  email backfill runs; writes are fail-soft until then)
PII_LOOKUP_HMAC_KEYS_JSON=               # HMAC keyring for blind-index contact lookup

# ─────────────────────────────────────────────────────────────────────────────
# Stripe — STRIPE_SECRET_KEY + STRIPE_WEBHOOK_SECRET required for payments
# ─────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=
STRIPE_CHECKOUT_SUCCESS_URL=
STRIPE_CHECKOUT_CANCEL_URL=
STRIPE_CONNECT_RETURN_URL=
STRIPE_CONNECT_REFRESH_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Supabase (storage + service role)
# ─────────────────────────────────────────────────────────────────────────────
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Email — Postmark (prod-required: server token + a from address)
# ─────────────────────────────────────────────────────────────────────────────
POSTMARK_SERVER_TOKEN=
POSTMARK_NOTIFICATION_FROM_EMAIL=        # preferred notification from-address
POSTMARK_FROM_EMAIL=                     # fallback from-address
POSTMARK_MESSAGE_STREAM=outbound
POSTMARK_WEBHOOK_USERNAME=               # inbound delivery-event webhook basic-auth
POSTMARK_WEBHOOK_PASSWORD=
POSTMARK_WEBHOOK_TOKEN=
POSTMARK_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# SMS — Twilio (gated on config; silent-fail guarded)
# ─────────────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_NOTIFICATION_FROM_NUMBER=
TWILIO_NOTIFICATION_STATUS_CALLBACK_URL=
TWILIO_VERIFY_SERVICE_SID=
SMS_ALLOWED_COUNTRIES=US                 # comma-separated ISO country codes

# ─────────────────────────────────────────────────────────────────────────────
# Push — APNs (iOS) + FCM (Android)   [native PUSH channel]
# Fully OPTIONAL. While unset, the PUSH channel stays inert (no device tokens are
# queried, no PUSH deliveries created). Setting BOTH an APNs block AND/OR the FCM
# block flips isPushProviderConfigured() → push goes live for PUSH-default events.
# See docs/mobile/push-go-live-runbook.md for how to obtain each value.
# ─────────────────────────────────────────────────────────────────────────────
APNS_AUTH_KEY=                            # contents of the .p8 APNs auth key (PEM text)
APNS_KEY_ID=                             # 10-char Key ID of the .p8
APNS_TEAM_ID=                            # Apple Developer Team ID
APNS_BUNDLE_ID=                          # iOS app bundle identifier (apns-topic)
APNS_ENV=production                      # 'production' or 'sandbox' (match the build type)
FCM_SERVICE_ACCOUNT_JSON=                # entire Firebase service-account JSON (one value)
FCM_PROJECT_ID=                          # Firebase project id

# ─────────────────────────────────────────────────────────────────────────────
# Google Maps / geocoding & address verification
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=
DCA_SEARCH_APP_ID=                       # license verification provider
DCA_SEARCH_APP_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Turnstile (captcha)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Redis / KV (rate limiting, idempotency) — Upstash
# ─────────────────────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
KV_REST_API_URL=                         # Vercel KV alias (if used)
KV_REST_API_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# Observability — Sentry (DSN prod-required)
# ─────────────────────────────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_DIST=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_ENABLE_LOGS=
ENABLE_SENTRY_DEBUG_ROUTE=               # dev-only: expose the Sentry debug route

# ─────────────────────────────────────────────────────────────────────────────
# Internal jobs / cron — a secret is prod-required
# Sent as `Authorization: Bearer <secret>` or `x-internal-job-secret: <secret>`.
# INTERNAL_JOB_SECRET takes precedence over CRON_SECRET.
# ─────────────────────────────────────────────────────────────────────────────
INTERNAL_JOB_SECRET=replace-with-a-long-random-string
CRON_SECRET=                             # fallback if INTERNAL_JOB_SECRET is unset

# ─────────────────────────────────────────────────────────────────────────────
# Anthropic (Claude vision for the native AI camera — /api/v1/pro/camera/*)
# ─────────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
CAMERA_VISION_MODEL=                     # optional override; defaults to claude-opus-4-8

# ─────────────────────────────────────────────────────────────────────────────
# Feature flags (default OFF unless set)
# ─────────────────────────────────────────────────────────────────────────────
ENABLE_PRO_MIGRATION=
ENABLE_SERVICE_PERMISSION_FILTER=
ENABLE_CLIENT_TECHNICAL_RECORD=
LIFECYCLE_STRICT_MODE=

# ─────────────────────────────────────────────────────────────────────────────
# Tunables (sensible defaults if unset)
# ─────────────────────────────────────────────────────────────────────────────
TOVIS_DISCOVERY_FEE_CENTS=               # platform discovery fee in cents
TOVIS_TOS_VERSION=                       # current Terms-of-Service version string
STALE_PENDING_HOURS=                     # stale-session sweep thresholds
STALE_IN_PROGRESS_HOURS=
HEALTH_CHECK_PROVIDERS_LIVE=             # health route: probe live providers
HEALTH_READY_DEGRADED_RETURNS_503=
