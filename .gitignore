# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.env.local
.env.test.local
# ...but the documented template IS committed
!.env.example


# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

# Claude Code local config
.claude/
.vercel
.env*.local

# Local logs
*.log
logs/
server.log

playwright-report/
playwright/.auth/
test-results/

.env*.local
.env.staging.local

# Local-only dev scratch tools (machine-specific paths)
.tovis-smoke-watch.cjs
# TypeScript incremental build cache
tsconfig.tsbuildinfo

# Claude Design handoff bundle (reference only)
docs/design/brand-handoff/
# Design handoff zip bundles dropped in the repo root (reference-only, not source)
*handoff*.zip

# Perf-run output written by tests/e2e/availability.perf.spec.ts (and by the
# perf-availability workflow, which mkdir -p's it and uploads it via
# actions/upload-artifact — unaffected by this ignore).
artifacts/

# Internal docs (plans, audits, specs, runbooks) stay LOCAL, off the public repo.
# The whole docs/ tree is untracked on purpose (Tori, 2026-07-22): files remain on
# disk where every code comment / handoff pointer already references them, they
# just never get pushed. Nothing in the build/CI/runtime reads a doc file — all
# references are comments — so this breaks nothing. Re-track a subpath with
# `git add -f docs/<path>` if something ever needs to be public again.
docs/
