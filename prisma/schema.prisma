  CLIENT_CLAIM_INVITE
  CONSULTATION_PROPOSAL_SENT
  CONSULTATION_APPROVED
  CONSULTATION_REJECTED
  REVIEW_RECEIVED
  // Post-visit "leave a review" nudge to the client, scheduled a few hours
  // after the booking completes (lib/notifications/reviewRequests.ts).
  REVIEW_REQUESTED
  APPOINTMENT_REMINDER
  AFTERCARE_READY
  LAST_MINUTE_OPENING_AVAILABLE
  // A pro proposed a specific appointment time to a waitlisted client; the
  // client must Confirm before it books (see WaitlistOffer).
  WAITLIST_TIME_OFFERED
  VIRAL_REQUEST_APPROVED
  PAYMENT_COLLECTED
  PAYMENT_ACTION_REQUIRED
  // An off-platform payment (cash / Venmo / Zelle / Apple Cash / PayPal) is
  // awaiting the pro's confirmation of receipt. Pro-facing: confirming it both
  // closes out the current booking's payment AND approves any aftercare-sourced
  // next appointment coupled to it (see confirmProBookingPaymentReceived).
  PAYMENT_CONFIRMATION_REQUIRED
  // Refund receipt (final-bill or deposit refund) — emitted from the refund
  // reconcile paths.
  PAYMENT_REFUNDED
  // A no-show / late-cancel fee was charged to the client's saved card (Phase 2
  // revenue protection). Client-facing receipt; inert unless the flag is on.
  NO_SHOW_FEE_CHARGED
  LOOK_FOLLOWER_NEW
  // Client→client follow ("started following you") — powers the activity feed.
  CLIENT_FOLLOW
  // Someone commented on your look — routed to the look's author (the pro, or
  // the client author for client-shared looks).
  LOOK_COMMENTED
  // Someone replied to your comment on a look — routed to the parent comment's
  // author (pro or client).
  LOOK_COMMENT_REPLIED
  // Batched "your look got liked" — one refreshed inbox row per look per day
  // (windowed dedupeKey), count carried in data. Routed to the look's author.
  LOOK_LIKED
  // Batched "your look got saved to a board" — same windowed-dedupe shape as
  // LOOK_LIKED. Routed to the look's author.
  LOOK_SAVED
  // A pro you follow published a new look — fanned out to ProFollow followers
  // via the FAN_OUT_NEW_LOOK_NOTIFICATIONS job.
  LOOK_NEW_FROM_FOLLOWED_PRO
  // "Your look hit N likes / N saves" — a one-time supply-side growth nudge to
  // the look's author (pro, or client author) each time a like/save threshold is
  // crossed. Fires once per (look, metric, threshold) via a permanent dedupeKey.
  LOOK_MILESTONE_REACHED
  REFERRAL_TAP_RECEIVED
  REFERRAL_CONFIRMED
  REFERRAL_CONVERTED

  // A new message landed in a thread the recipient participates in. Routed to
  // the OTHER participant (client or pro). Debounced per thread per recipient so
  // a rapid burst refreshes one inbox row / fires one push rather than spamming.
  MESSAGE_RECEIVED

  // A not-yet-premium pro's reserved vanity handle is about to be released for
  // inactivity. Heads-up before the expiry cron reclaims it.
  PRO_HANDLE_RESERVATION_EXPIRING

  // Admin operational alerts — fanned out to all users with role ADMIN.
  // A pro submitted a verification document or edited their license (re-review).
  ADMIN_VERIFICATION_REVIEW_NEEDED
  // A new support ticket was created.
  ADMIN_SUPPORT_TICKET_CREATED
  // A new viral-service request is pending an admin decision.
  ADMIN_VIRAL_REQUEST_PENDING
}

