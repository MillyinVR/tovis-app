// A single refund issued against a booking's captured Stripe payment. Multiple
// rows per booking support partial + repeated refunds; the cumulative SUCCEEDED
// amount drives Booking.stripePaymentStatus. stripeRefundId is unique so the
// charge.refunded webhook can reconcile back to the exact row.
model BookingRefund {
  id        String  @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  // Requested amount in the booking's Stripe currency minor units (cents).
  amountCents Int
  currency    String @db.VarChar(3)

  status  BookingRefundStatus  @default(PENDING)
  trigger BookingRefundTrigger

  // reverseTransfer claws the destination transfer back from the pro (client made
  // whole); applicationFeeRefunded records whether a platform fee was also refunded
  // (only ever true once application fees are charged — currently none are).
  reverseTransfer        Boolean @default(true)
  applicationFeeRefunded Boolean @default(false)

  // Audit. Null initiatedBy* for automatic policy refunds with no explicit actor.
  initiatedByUserId String?
  initiatedByRole   Role?
  reason            String? @db.VarChar(500)

  // Stripe linkage. stripeRefundId is unique → idempotent create + webhook reconcile.
  stripePaymentIntentId String?
  stripeRefundId        String? @unique
  failureCode           String?
  failureMessage        String? @db.VarChar(500)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId])
  @@index([status])
}

