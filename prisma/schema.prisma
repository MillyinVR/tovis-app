}

// Which clients a pro's deposit requirement applies to. The one-time platform
// discovery fee is ALWAYS limited to the new-via-discovery subset regardless of
// this setting — this only widens who must leave a deposit.
enum DepositScope {
  NEW_DISCOVERY_ONLY // only brand-new clients found via Looks/Discovery (default)
  ALL_NEW_CLIENTS // any first-time client, however they arrived
  ALL_CLIENTS // every booking
}

// How a client arrived at the pro for a given booking. Server-validated at hold
// creation and copied to the Booking at finalize — it is a TRUST BOUNDARY and is
// never taken from client input, because LOOKS_FEED / DISCOVERY_SEARCH gate the
// one-time platform fee.
enum BookingDiscoveryProvenance {
  UNKNOWN // not determined / legacy rows
  LOOKS_FEED // tapped a Look in the Looks feed (validated LookPost for this pro)
  DISCOVERY_SEARCH // found via the Discovery tab / service browse (server attribution)
  DIRECT_PROFILE // opened the pro's profile directly
  NAME_SEARCH // searched the pro by name / handle / email
  NFC // arrived via the pro's NFC card
  AFTERCARE // rebooked from an aftercare summary
  PRO_CREATED // the pro created the booking
}

// Lifecycle of a new-client deposit charge (separate from the final bill).
enum BookingDepositStatus {
  NONE // no deposit required for this booking
  PENDING // deposit checkout created, not yet paid
  PAID // deposit captured (may be PARTIALLY refunded — see depositRefundedCents)
  REFUNDED // deposit FULLY refunded (partial refunds stay PAID + accumulate depositRefundedCents)
  FAILED // deposit charge failed / expired
}

