model ClientAddress {
  id        String            @id @default(cuid())
  clientId  String
  kind      ClientAddressKind
  label     String?
  isDefault Boolean           @default(false)

  formattedAddress String?
  addressLine1     String?
  addressLine2     String?
  city             String?
  state            String?
  postalCode       String?
