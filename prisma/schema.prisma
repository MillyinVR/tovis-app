  // ✅ context-scoped
  contextType MessageThreadContextType
  contextId   String // bookingId OR serviceId OR offeringId OR professionalId OR waitlistEntryId

  // Optional pointers for convenience.
  // These make joins explicit while contextType/contextId remains the canonical uniqueness guard.
  bookingId       String?        @unique
  booking         Booking?       @relation("BookingThreads", fields: [bookingId], references: [id], onDelete: SetNull)
  serviceId       String?
  offeringId      String?
  waitlistEntryId String?        @unique
  waitlistEntry   WaitlistEntry? @relation("WaitlistThread", fields: [waitlistEntryId], references: [id], onDelete: SetNull)

