// =======================
// CORE MODELS
// =======================
model Notification {
  id String @id @default(cuid())

  eventKey NotificationEventKey
  priority NotificationPriority @default(NORMAL)

  professionalId String
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  actorUserId String?
  actorUser   User?   @relation("NotificationActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  reviewId String?
  review   Review? @relation(fields: [reviewId], references: [id], onDelete: SetNull)

  title String
  body  String @default("")
  href  String @default("")

  // structured payload for UI + future-proofing
  data Json?

  dedupeKey String?

  // state
  seenAt     DateTime?
  readAt     DateTime?
  clickedAt  DateTime?
  archivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dispatches                  NotificationDispatch[]       @relation("ProNotificationDispatches")
  viralRequestApprovalFanOuts ViralRequestApprovalFanOut[]

  @@unique([professionalId, dedupeKey])
  // main inbox query
  @@index([professionalId, archivedAt, readAt, createdAt])
  // filters
  @@index([professionalId, eventKey, archivedAt, createdAt])
  @@index([professionalId, priority, archivedAt, createdAt])
  @@index([bookingId])
  @@index([reviewId])
}

model NotificationDispatch {
  id String @id @default(cuid())

  // stable idempotency key for the source of this dispatch
  // examples:
  //   pro-notification:<notificationId>
  //   client-notification:<clientNotificationId>
  //   scheduled-client:<scheduledNotificationId>
  //   booking:<bookingId>:reminder:24h
  sourceKey String @unique

  eventKey      NotificationEventKey
  recipientKind NotificationRecipientKind
  priority      NotificationPriority      @default(NORMAL)

  userId         String?
  professionalId String?
  clientId       String?

  // durable recipient snapshot for delivery-time policy, audit, and retries
  recipientInAppTargetId String? @db.VarChar(64)
  recipientPhone         String? @db.VarChar(32)
  recipientEmail         String? @db.VarChar(320)
  recipientTimeZone      String? @db.VarChar(64)

  // optional links back to product-facing inbox records
  notificationId       String?
  clientNotificationId String?

  title   String
  body    String @default("")
  href    String @default("")
  payload Json?

  scheduledFor DateTime  @default(now())
  cancelledAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User?                @relation("UserNotificationDispatches", fields: [userId], references: [id], onDelete: SetNull)
  professional ProfessionalProfile? @relation("ProfessionalNotificationDispatches", fields: [professionalId], references: [id], onDelete: Cascade)
  client       ClientProfile?       @relation("ClientProfileNotificationDispatches", fields: [clientId], references: [id], onDelete: Cascade)

  notification       Notification?       @relation("ProNotificationDispatches", fields: [notificationId], references: [id], onDelete: SetNull)
  clientNotification ClientNotification? @relation("ClientInboxNotificationDispatches", fields: [clientNotificationId], references: [id], onDelete: SetNull)

  deliveries                  NotificationDelivery[]
  viralRequestApprovalFanOuts ViralRequestApprovalFanOut[]

  @@index([recipientKind, scheduledFor, createdAt])
  @@index([professionalId, createdAt])
  @@index([clientId, createdAt])
  @@index([userId, createdAt])
  @@index([notificationId])
  @@index([clientNotificationId])
}

model NotificationDelivery {
  id String @id @default(cuid())

  dispatchId String
  channel    NotificationChannel
  provider   NotificationProvider

  status NotificationDeliveryStatus @default(PENDING)

  // destination snapshot used at send time
  destination     String?
  templateKey     String
  templateVersion Int     @default(1)

  attemptCount Int @default(0)
  maxAttempts  Int @default(5)

  nextAttemptAt DateTime  @default(now())
  lastAttemptAt DateTime?

  claimedAt      DateTime?
  leaseExpiresAt DateTime?
  leaseToken     String?

  providerMessageId String?
  providerStatus    String?

  lastErrorCode    String?
  lastErrorMessage String?

  sentAt       DateTime?
  deliveredAt  DateTime?
  failedAt     DateTime?
  suppressedAt DateTime?
  cancelledAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dispatch NotificationDispatch        @relation(fields: [dispatchId], references: [id], onDelete: Cascade)
  events   NotificationDeliveryEvent[]

  @@unique([dispatchId, channel])
  @@index([status, nextAttemptAt])
  @@index([leaseExpiresAt])
  @@index([provider, providerMessageId])
}

model NotificationDeliveryEvent {
  id String @id @default(cuid())

  deliveryId    String
  attemptNumber Int?

  type       NotificationDeliveryEventType
  fromStatus NotificationDeliveryStatus?
  toStatus   NotificationDeliveryStatus?

  providerStatus    String?
  providerMessageId String?

  errorCode    String?
  errorMessage String?
  message      String?

  payload Json?

  createdAt DateTime @default(now())

  delivery NotificationDelivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId, createdAt])
  @@index([type, createdAt])
}

model ProfessionalNotificationPreference {
  id             String               @id @default(cuid())
  professionalId String
  eventKey       NotificationEventKey

  inAppEnabled Boolean @default(true)
  smsEnabled   Boolean @default(false)
  emailEnabled Boolean @default(true)

  quietHoursStartMinutes Int?
  quietHoursEndMinutes   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  professional ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([professionalId, eventKey])
  @@index([professionalId, updatedAt])
}

model ClientNotificationPreference {
  id       String               @id @default(cuid())
  clientId String
  eventKey NotificationEventKey

  inAppEnabled Boolean @default(true)
  smsEnabled   Boolean @default(true)
  emailEnabled Boolean @default(true)

  quietHoursStartMinutes Int?
  quietHoursEndMinutes   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, eventKey])
  @@index([clientId, updatedAt])
}

model ConsultationApproval {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status     ConsultationApprovalStatus @default(PENDING)
  approvedAt DateTime?
  rejectedAt DateTime?

  proposedServicesJson Json
  proposedTotal        Decimal?
  notes                String?

  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  clientId String?
  proId    String?

  proof              ConsultationApprovalProof?
  clientActionTokens ClientActionToken[]

  @@index([status])
}

model ClientActionToken {
  id String @id @default(cuid())

  kind      ClientActionTokenKind
  tokenHash String                @unique @db.VarChar(128)
  singleUse Boolean               @default(true)

  bookingId              String
  consultationApprovalId String?
  aftercareSummaryId     String?
  clientId               String
  professionalId         String

  deliveryMethod         ContactMethod?
  recipientEmailSnapshot String?        @db.VarChar(320)
  recipientPhoneSnapshot String?        @db.VarChar(32)

  issuedByUserId String?

  expiresAt   DateTime
  firstUsedAt DateTime?
  lastUsedAt  DateTime?
  useCount    Int       @default(0)

  revokedAt    DateTime?
  revokeReason String?

  metadata Json?

  booking              Booking               @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  consultationApproval ConsultationApproval? @relation(fields: [consultationApprovalId], references: [id], onDelete: Cascade)
  aftercareSummary     AftercareSummary?     @relation(fields: [aftercareSummaryId], references: [id], onDelete: Cascade)
  client               ClientProfile         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  professional         ProfessionalProfile   @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  issuedByUser         User?                 @relation("IssuedClientActionTokens", fields: [issuedByUserId], references: [id], onDelete: SetNull)

  proof ConsultationApprovalProof? @relation("ConsultationProofActionToken")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kind, expiresAt])
  @@index([bookingId, kind, createdAt])
  @@index([consultationApprovalId, kind, createdAt])
  @@index([aftercareSummaryId, kind, createdAt])
  @@index([clientId, kind, createdAt])
  @@index([professionalId, kind, createdAt])
  @@index([issuedByUserId, createdAt])
}

model ConsultationApprovalProof {
  id String @id @default(cuid())

  consultationApprovalId String @unique
  bookingId              String @unique
  clientId               String
  professionalId         String

  decision ConsultationDecision
  method   ConsultationApprovalProofMethod

  actedAt DateTime @default(now())

  recordedByUserId    String?
  clientActionTokenId String? @unique

  contactMethod       ContactMethod?
  destinationSnapshot String?        @db.VarChar(320)
  ipAddress           String?        @db.VarChar(64)
  userAgent           String?
  contextJson         Json?

  consultationApproval ConsultationApproval @relation(fields: [consultationApprovalId], references: [id], onDelete: Cascade)
  booking              Booking              @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  client               ClientProfile        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  professional         ProfessionalProfile  @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  recordedByUser       User?                @relation("RecordedConsultationApprovalProofs", fields: [recordedByUserId], references: [id], onDelete: SetNull)
  clientActionToken    ClientActionToken?   @relation("ConsultationProofActionToken", fields: [clientActionTokenId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId, actedAt])
  @@index([professionalId, actedAt])
  @@index([method, actedAt])
  @@index([decision, actedAt])
  @@index([recordedByUserId, actedAt])
}

model AdminPermission {
  id String @id @default(cuid())

  adminUserId String
  role        AdminPermissionRole @default(SUPPORT)

  // Option A scopes (all optional)
  professionalId String?
  serviceId      String?
  categoryId     String?

  createdAt DateTime @default(now())

  adminUser    User                 @relation(fields: [adminUserId], references: [id])
  professional ProfessionalProfile? @relation(fields: [professionalId], references: [id])
  service      Service?             @relation(fields: [serviceId], references: [id])
  category     ServiceCategory?     @relation(fields: [categoryId], references: [id])

  // Prevent obvious duplicates
  @@unique([adminUserId, role, professionalId, serviceId, categoryId])
  @@index([adminUserId, createdAt])
  @@index([professionalId])
  @@index([serviceId])
  @@index([categoryId])
}

model User {
  id              String    @id @default(cuid())
  email           String?   @unique @db.VarChar(320)
  phone           String?   @unique @db.VarChar(32)
  phoneVerifiedAt DateTime?
  emailVerifiedAt DateTime?

  lookLikes    LookLike[]
  lookComments LookComment[]

  lookPostReports    LookPostReport[]
  lookCommentReports LookCommentReport[]

  reviewedLookPosts          LookPost[]                  @relation("LookPostReviewedByUser")
  reviewedLookComments       LookComment[]               @relation("LookCommentReviewedByUser")
  viralServiceRequestReports ViralServiceRequestReport[]

  tosAcceptedAt DateTime?
  tosVersion    String?

  transactionalSmsConsentAt        DateTime?
  transactionalSmsConsentVersion   String?   @db.VarChar(64)
  transactionalSmsConsentSource    String?   @db.VarChar(64)
  transactionalSmsConsentIp        String?   @db.VarChar(64)
  transactionalSmsConsentUserAgent String?

  authVersion        Int                        @default(1)
  loginAttempts      Int                        @default(0)
  lockedUntil        DateTime?
  password           String
  role               Role
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  reviewHelpfulVotes ReviewHelpful[]
  favoriteServices   ServiceFavorite[]
  adminActionLogs    AdminActionLog[]           @relation("AdminUserLogs")
  adminPermissions   AdminPermission[]
  sentMessages       Message[]                  @relation("UserSentMessages")
  threadParticipants MessageThreadParticipant[] @relation("UserThreadParticipants")

  notificationActor                  Notification[]              @relation("NotificationActor")
  notificationDispatches             NotificationDispatch[]      @relation("UserNotificationDispatches")
  issuedClientActionTokens           ClientActionToken[]         @relation("IssuedClientActionTokens")
  recordedConsultationApprovalProofs ConsultationApprovalProof[] @relation("RecordedConsultationApprovalProofs")
  bookingOverrideAuditLogs           BookingOverrideAuditLog[]   @relation("BookingOverrideActor")
  acceptedProClientInvites           ProClientInvite[]           @relation("ProClientInviteAcceptedByUser")
  revokedProClientInvites            ProClientInvite[]           @relation("ProClientInviteRevokedByUser")

  bookingOverridePermissionsGranted BookingOverridePermission[] @relation("BookingOverridePermissionGrantedBy")
  bookingOverridePermissionsRevoked BookingOverridePermission[] @relation("BookingOverridePermissionRevokedBy")
  bookingOverridePermissionsAsActor BookingOverridePermission[] @relation("BookingOverridePermissionActor")

  bookingCloseoutAuditLogs BookingCloseoutAuditLog[] @relation("BookingCloseoutActor")

  // NFC attribution events
  attributionActorEvents    AttributionEvent[] @relation("AttributionActor")
  attributionCreditedEvents AttributionEvent[] @relation("AttributionCredited")

  // favorites (clients favoriting pros)
  favoritePros ProfessionalFavorite[]

  // role profiles
  clientProfile       ClientProfile?
  professionalProfile ProfessionalProfile?

  // media interactions
  mediaLikes    MediaLike[]
  mediaComments MediaComment[]

  // opposite relation for MediaAsset.uploadedByUser
  uploadedMedia           MediaAsset[]             @relation("UploadedMedia")
  nfcCards                NfcCard[]
  tapIntents              TapIntent[]
  passwordResetTokens     PasswordResetToken[]
  phoneVerifications      PhoneVerification[]
  emailVerificationTokens EmailVerificationToken[]

  supportTicketsCreated SupportTicket[]        @relation("SupportTicketCreatedBy")
  supportTicketsHandled SupportTicket[]        @relation("SupportTicketHandledBy")
  verificationDocuments VerificationDocument[]
  viralServiceRequests  ViralServiceRequest[]  @relation("ViralServiceRequestReviewedByUser")
}

model PhoneVerification {
  id        String    @id @default(cuid())
  userId    String
