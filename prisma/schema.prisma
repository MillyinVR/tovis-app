  discoveryProvenance BookingDiscoveryProvenance @default(UNKNOWN)

  // New-client deposit captured up front, as its OWN charge (distinct from the
  // final bill's stripe* fields). The deposit credits toward the final total.
  depositStatus                BookingDepositStatus @default(NONE)
  depositStripePaymentIntentId String?              @unique
  depositStripeChargeId        String?
