// A registered push-notification target for one user's device/install. Native
// apps register their APNs/FCM token here on launch (and after refresh); the
// notification engine fans a PUSH delivery out to all of a user's active tokens
// (wired in a later phase). A token is globally unique to one install, so it is
// reassigned to the current user on re-login rather than duplicated.
model DeviceToken {
  id     String @id @default(cuid())
  userId String

  platform DevicePlatform
  token    String         @db.VarChar(512)

  // Optional stable per-install id from the client (survives token refresh).
  deviceId String? @db.VarChar(128)

  isActive   Boolean   @default(true)
  lastSeenAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation("UserDeviceTokens", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([platform, token])
  @@index([userId, isActive])
}

enum DevicePlatform {
  IOS
  ANDROID
}

/// Per-device session revocation. The auth session is a stateless JWT keyed only
/// by the per-user `authVersion` (bumping it kills EVERY session). To revoke a
/// single lost/stolen device without signing the user out everywhere, a native
/// session token also carries a stable `deviceId` claim; revoking sets
/// `revokedAt` here and `getCurrentUser` rejects any token for that
/// `(userId, deviceId)` whose issued-at (`iat`) is at or before `revokedAt`. A
/// later re-login mints a fresher token that passes again, so one row per device
/// (upserted) is enough — no per-token bookkeeping.
model DeviceSessionRevocation {
  id     String @id @default(cuid())
  userId String

  // Matches DeviceToken.deviceId (the stable per-install id the client sends).
  deviceId String @db.VarChar(128)

  // Tokens for this device issued at or before this instant are rejected.
  revokedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation("UserDeviceSessionRevocations", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId])
}

