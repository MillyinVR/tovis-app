model LookPost {
  id                  String  @id @default(cuid())
  // professionalId is the ORIGIN pro of the look (the pro whose work it shows /
  // who is tagged). For pro-authored looks this is also the author. For
  // client-authored looks (clientAuthorId set) it stays the visited pro, so the
  // existing pro-keyed indexes/relations are unchanged. Pro-facing portfolio
  // queries must filter `clientAuthorId: null` to exclude client-authored looks.
  professionalId      String
  // Null = pro-authored (today's behavior). Set = the client who published this
  // look from their visit (engagement loop / Share-your-look capture).
  clientAuthorId      String?
  primaryMediaAssetId String  @unique
  serviceId           String?

  caption         String?
  priceStartingAt Decimal? @db.Decimal(10, 2)

  status           LookPostStatus     @default(DRAFT)
  visibility       LookPostVisibility @default(PUBLIC)
  moderationStatus ModerationStatus   @default(APPROVED)
  // Client-authored discovery gate (social-first C2). For client-authored looks
  // (clientAuthorId set) this must be true before the look enters the public
  // discovery feed — an explicit per-look opt-in, independent of the author's
  // ClientProfile.isPublicProfile. Pro-authored looks are admitted by
  // buildLooksFeedWhere via `clientAuthorId: null` and ignore this flag (it stays
  // false for them). See lib/looks/feed.ts + clientLookService.ts.
  publicToFeed     Boolean            @default(false)

  publishedAt DateTime?
  archivedAt  DateTime?
  removedAt   DateTime?

  reviewedAt       DateTime?
  reviewedByUserId String?
  adminNotes       String?
  reportCount      Int       @default(0)

  // Admin editorial curation (social-first AM1). featuredAt != null = a
  // SUPER_ADMIN promoted this look into the Spotlight feed — an honest editorial
  // signal (see buildLookPostSpotlightEligibilityWhere), never a faked engagement
  // count. featuredByUserId is a plain admin User id (no relation, #481 audit
  // convention, matches Review.hiddenByAdminUserId).
  featuredAt       DateTime?
  featuredByUserId String?

  likeCount    Int @default(0)
  commentCount Int @default(0)
  saveCount    Int @default(0)
  shareCount   Int @default(0)
  // Sampled/denormalized view total (feed impressions + detail opens). Written
  // only by the APPLY_LOOK_VIEWS LooksSocialJob — never a synchronous insert on
  // the view hot path. Social-first plan B2.
  viewCount    Int @default(0)

  spotlightScore Float @default(0)
  rankScore      Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  professional      ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  clientAuthor      ClientProfile?      @relation("ClientAuthoredLooks", fields: [clientAuthorId], references: [id], onDelete: Cascade)
  primaryMediaAsset MediaAsset          @relation("PrimaryLookMediaAsset", fields: [primaryMediaAssetId], references: [id], onDelete: Restrict)
  service           Service?            @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  reviewedByUser    User?               @relation("LookPostReviewedByUser", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  assets           LookPostAsset[]
  likes            LookLike[]
  comments         LookComment[]
  reports          LookPostReport[]
  boardItems       BoardItem[]
  // §6.0 visual embedding of the primary image (written by the
  // EMBED_LOOK_POST_IMAGE job; absent until the look is embedded).
  embedding        LookPostEmbedding?
  // §5.6 per-source, per-day impression aggregates (written by the
  // APPLY_LOOK_VIEWS job); the anti-gaming velocity-check denominator breakdown.
  impressionStats  LookPostImpressionStat[]
  inspiredBookings Booking[]                @relation("LookInspiredBookings")
  // User-facing hashtags / style tags parsed from the caption at publish
  // (social-first D1). Implicit M2M; banned tags are dropped at publish and
  // their tag pages 404. See lib/looks/tags.ts.
  tags             LookTag[]                @relation("LookPostTags")

  @@index([professionalId, publishedAt])
  @@index([serviceId, publishedAt])
  @@index([status, visibility, publishedAt])
  @@index([moderationStatus, publishedAt])
  @@index([rankScore, publishedAt])
  @@index([spotlightScore, publishedAt])
  @@index([moderationStatus, reportCount, createdAt])
  @@index([reviewedByUserId, reviewedAt])
  @@index([featuredAt])
  @@index([professionalId, status, updatedAt])
  @@index([professionalId, visibility, updatedAt])
  @@index([clientAuthorId, status, updatedAt])
  @@index([clientAuthorId, visibility, publishedAt])
}

// User-facing hashtag / style tag for Looks (social-first D1). `slug` is the
// normalized key (lowercase, ascii, hyphenless) parsed from a caption's #tags;
// `display` is the first-seen human form. A banned tag (bannedAt set) is dropped
// at publish and its /looks/tags/[slug] page 404s. Tag → LookPost is an implicit
// M2M (join table _LookPostTags). See lib/looks/tags.ts.
model LookTag {
  id        String     @id @default(cuid())
  slug      String     @unique
  display   String
  bannedAt  DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  looks     LookPost[] @relation("LookPostTags")

  @@index([bannedAt])
}

