model MediaAsset {
  id               String              @id @default(cuid())
  professionalId   String
  // Tenant of the owning pro (derived from professional.homeTenantId).
  // Expand phase: nullable + backfilled; a follow-up contract migration makes
  // it NOT NULL. See finish-plan T2.2.
  proTenantId      String?
  bookingId        String?
  reviewId         String?
  // Opt-in before/after pairing: on the *displayed* asset (the "after" a pro
  // features to portfolio, or the after-photo of a review), points at the
  // chosen "before" counterpart so surfaces can render the comparison slider
  // (BeforeAfterReveal / BeforeAfterCompareView). Null = show as a single tile.
  // Self-relation, nullable; onDelete SetNull so deleting a before never
  // cascades to the after that references it.
  beforeAssetId    String?
  // Every media asset is anchored to a primary bookable service so it can always
  // route to "book this" (the product goal: media → easy booking). Required by
  // DB constraint + by the MediaAssetWriteInput type (single create choke point,
  // lib/media/recordMediaAsset.ts). Derived at creation from booking.serviceId
  // (session/review photos) or the first selected service (portfolio uploads).
  // Extra/secondary services still live in the MediaServiceTag M2M below.
  // (License/verification docs are NOT MediaAssets — they use VerificationDocument.)
  primaryServiceId String
  uploadedByUserId String?
  uploadedByRole   Role?
  url              String?
  thumbUrl         String?
  mediaType        MediaType
  caption          String?
  createdAt        DateTime            @default(now())
  intentEvents     ClientIntentEvent[]

  lookPostPrimaryFor LookPost[]      @relation("PrimaryLookMediaAsset")
  lookPostAssets     LookPostAsset[] @relation("LookPostAssetMedia")

  visibility            MediaVisibility @default(PUBLIC)
  isFeaturedInPortfolio Boolean         @default(false)
  isEligibleForLooks    Boolean         @default(false)
  reviewLocked          Boolean         @default(false)

  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id])
  proTenant      Tenant?             @relation("TenantMediaAssets", fields: [proTenantId], references: [id], onDelete: Restrict)
  booking        Booking?            @relation(fields: [bookingId], references: [id])
  review         Review?             @relation(fields: [reviewId], references: [id])
  beforeAsset    MediaAsset?         @relation("MediaBeforeAfterPair", fields: [beforeAssetId], references: [id], onDelete: SetNull)
  pairedAsAfter  MediaAsset[]        @relation("MediaBeforeAfterPair")
  // Back-relations for the aftercare "featured pair" (which before/after this
  // asset is the pro-chosen primary of, per AftercareSummary). Aftercare-only,
  // stays PRO_CLIENT — never touches portfolio featuring/visibility.
  featuredInAftercareBefore AftercareSummary[] @relation("AftercareFeaturedBefore")
  featuredInAftercareAfter  AftercareSummary[] @relation("AftercareFeaturedAfter")
  primaryService Service             @relation("MediaPrimaryService", fields: [primaryServiceId], references: [id])
  phase          MediaPhase          @default(OTHER)
  uploadedByUser User?               @relation("UploadedMedia", fields: [uploadedByUserId], references: [id])

  services MediaServiceTag[]
  likes    MediaLike[]
  comments MediaComment[]

  expenseReceipts ProfessionalExpense[]      @relation("ExpenseReceipt")
  receiptInbox    ProfessionalReceiptInbox[] @relation("ReceiptInboxMedia")

  waitlistEntries WaitlistEntry[]

  storageBucket String // 'media-public' | 'media-private'
  storagePath   String
  thumbBucket   String?
  thumbPath     String?

  // One MediaAsset per stored object. Prevents duplicate/orphaned rows pointing
  // at the same upload (e.g. a retried attach). Upload pointers are minted
  // server-side with timestamped/random paths, so legitimate rows never collide.
  @@unique([storageBucket, storagePath])
  @@index([professionalId, createdAt])
  @@index([professionalId, isEligibleForLooks, createdAt])
  @@index([professionalId, isFeaturedInPortfolio, createdAt])
  @@index([uploadedByUserId, createdAt])
  @@index([bookingId, phase, createdAt])
  @@index([bookingId, createdAt])
  @@index([proTenantId])
  @@index([primaryServiceId])
  @@index([beforeAssetId])
}

// UploadSession binds a server-minted signed-upload URL to the eventual
// MediaAsset it produces (finish-plan T2.1 / Phase 4). The signing routes create
// a PENDING session and return its id; the media-attach routes look the session
// up by id, validate it (owner / booking / phase / expiry / status), create the
// MediaAsset from the session's authoritative storage pointer, and mark the
// session CONSUMED. This closes two gaps: the client can no longer assert the
// storage path on attach (the server owns it), and orphaned objects (bytes
// uploaded but never attached) are discoverable as stale PENDING sessions for a
// cleanup job to reap.
//
// Context ids are snapshot columns (no FK relations), matching the booking
// attribution philosophy — they record who/what the upload was for at sign time.
enum UploadSurface {
  PRO_BOOKING_MEDIA
  PRO_LOOKS
  PRO_PORTFOLIO
  CLIENT_REVIEW
  // Client publishes a look from their visit (Share-your-look capture). Uploads
  // land in media-public (the client consents to a public-intent look asset),
  // optionally carrying a BEFORE/AFTER phase.
  CLIENT_LOOK
}

enum UploadSessionStatus {
  PENDING
  CONSUMED
  EXPIRED
}

model UploadSession {
  id      String              @id @default(cuid())
  surface UploadSurface
  status  UploadSessionStatus @default(PENDING)

  // Context snapshot (who/what this upload is for). Nullable because not every
  // surface knows every dimension at sign time (e.g. client review uploads only
  // know the client until the review is attached).
  tenantId       String?
  professionalId String?
  clientId       String?
  bookingId      String?
  phase          MediaPhase?

  // Authoritative storage pointer minted by the signing route. NEVER supplied by
  // the client on attach — the attach route reads it back from here.
  storageBucket  String
  storagePath    String
  contentType    String
  maxBytes       Int
  checksumSha256 String?

  // Lifecycle.
  expiresAt    DateTime
  consumedAt   DateTime?
  mediaAssetId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storageBucket, storagePath])
  @@index([status, expiresAt])
  @@index([professionalId])
  @@index([clientId])
  @@index([bookingId])
}

