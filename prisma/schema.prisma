model ProfessionalProfile {
  id     String @id @default(cuid())
  userId String @unique

  // The Pro's one home tenant (contract phase: required; creation sites
  // stamp it). Drives discovery visibility.
  homeTenantId String
  homeTenant   Tenant @relation("TenantHomePros", fields: [homeTenantId], references: [id], onDelete: Restrict)

  firstName       String    @default("")
  lastName        String    @default("")
  phone           String?
