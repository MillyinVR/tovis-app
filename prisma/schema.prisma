model ClientProfile {
  id     String  @id @default(cuid())
  userId String? @unique

  // Tenant the client signed up under (contract phase: required; creation
  // sites stamp it). Drives what the client can discover.
  homeTenantId String
  homeTenant   Tenant @relation("TenantHomeClients", fields: [homeTenantId], references: [id], onDelete: Restrict)

  firstName String @default("")
  lastName  String @default("")

  claimStatus ClientClaimStatus @default(UNCLAIMED)
  claimedAt   DateTime?

  email               String?   @unique @db.VarChar(320)
  emailHashV2         String?   @unique @db.VarChar(128)
  emailHashKeyVersion Int?
  // AEAD-encrypted envelope for the displayable email (expand→contract dual-write;
  // mirrors User.emailEncrypted). Plaintext `email` stays the source of truth during
  // burn-in; lookup hash (emailHashV2) is the separate, untouched query anchor.
  emailEncrypted      Json?
  phone               String?   @unique @db.VarChar(32)
  phoneHashV2         String?   @unique @db.VarChar(128)
  phoneHashKeyVersion Int?
  // AEAD-encrypted envelope for the displayable phone (expand→contract dual-write;
  // see docs/security/ticket-encrypt-phone-at-rest.md). Mirrors User.phoneEncrypted.
  phoneEncrypted      Json?
  phoneVerifiedAt     DateTime?
  avatarUrl           String?

  // Stripe Billing customer for client-side card-on-file (no-show protection,
  // Phase 2). Created lazily on first save-card (SetupIntent) and is the source
  // of truth for the customer id. Distinct from ProfessionalSubscription's
  // stripeCustomerId (pro membership billing). Inert unless
  // ENABLE_NO_SHOW_PROTECTION is on.
  stripeCustomerId String? @unique

  // Client-as-creator public identity (engagement loop). A client only becomes
  // publicly addressable once they opt in (isPublicProfile) and claim a handle;
  // both default off/null so existing clients are unaffected. Mirrors the
  // ProfessionalProfile handle/handleNormalized pattern.
  handle           String?
  handleNormalized String? @unique
  isPublicProfile  Boolean @default(false)
  publicBio        String?

  dateOfBirth            DateTime?
  preferredContactMethod ContactMethod?

  // Pro-captured chart context (PR3). occupation is health-adjacent free-text PII,
  // so it is stored ONLY as an AEAD envelope (no plaintext column) using the same
  // notesPrivacy boundary as other encrypted notes. proCapturedSocialHandle is the
  // handle a pro jots down for tagging the client on socials — distinct from the
  // client's own creator `handle` above, and low-sensitivity, so it stays plain.
  occupationEncrypted     Json?
  proCapturedSocialHandle String?

  // Photo-release consent (PR4 — flagged). Explicit per-client release state that
  // gates whether before/after photos may surface. The PUBLIC path is unchanged
  // (review-promotion only, see lib/media/publicShareGuard.ts); this is the
  // client's standing release decision. capturedBy is a soft snapshot id.
  photoReleaseStatus           PhotoReleaseStatus @default(NOT_SET)
  photoReleaseAt               DateTime?
  photoReleaseByProfessionalId String?

  // Personalization self-profile (spec §6.6): optional, fully user-entered chip
  // answers (hair type/length/color, skin type/concern) plus declared category
  // interests. Validated by lib/personalization/selfProfile.ts (the SSOT) on
  // write AND read — same pattern as Board.answers. Explicit-only by guardrail:
  // never inferred from photos or behavior; editable and clearable anytime.
  selfProfile          Json?
  selfProfileUpdatedAt DateTime?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  addresses ClientAddress[]

  intentEvents               ClientIntentEvent[]
  lastMinuteRecipients       LastMinuteRecipient[]
  notificationSettings       ClientNotificationSettings?
  notificationDispatches     NotificationDispatch[]         @relation("ClientProfileNotificationDispatches")
  notificationPreferences    ClientNotificationPreference[]
  consultationApprovalProofs ConsultationApprovalProof[]
  clientActionTokens         ClientActionToken[]
  messageThreads             MessageThread[]                @relation("ClientThreads")
  viralRequests              ViralServiceRequest[]
  alertBanner                String?

  bookings               Booking[]
  proClientInvites       ProClientInvite[]
  bookingHolds           BookingHold[]
  notes                  ClientProfessionalNote[]
  formulaEntries         ClientFormulaEntry[]
  consentRecords         ClientConsentRecord[]
  allergies              ClientAllergy[]
  reviews                Review[]
  reminders              Reminder[]
  notifications          ClientNotification[]
  scheduledNotifications ScheduledClientNotification[]
  waitlistEntries        WaitlistEntry[]
  waitlistOffers         WaitlistOffer[]

  referralsAsReferrer Referral[] @relation("ReferrerReferrals")
  referralsAsReferred Referral[] @relation("ReferredReferrals")

  followedPros ProFollow[]
  boards       Board[]

  // Cards this client has saved on file (card-on-file / no-show protection).
  paymentMethods ClientPaymentMethod[]

  // Engagement loop: looks this client authored from their visits, plus the
  // client→client follow graph (followers of this client / who they follow).
  authoredLooks LookPost[]     @relation("ClientAuthoredLooks")
  following     ClientFollow[] @relation("ClientFollowing")
  followers     ClientFollow[] @relation("ClientFollowers")

  // Global visual taste vector (personalization spec §6.0) — decayed,
  // signal-weighted average of the embeddings of what this client liked/saved.
  tasteVector ClientTasteVector?

  @@index([claimStatus])
  @@index([emailHashKeyVersion])
  @@index([phoneHashKeyVersion])
  @@index([homeTenantId])
  @@index([handleNormalized])
}

/// A card a client has saved on file for card-on-file / no-show protection
/// (Phase 2). Mirrors the payment methods attached to `ClientProfile.stripeCustomerId`
/// in Stripe; Stripe stays the source of truth for the card itself while this row
/// caches display metadata (brand/last4/exp) and the default flag so the app can
/// list saved cards without a Stripe round-trip. Inert unless
/// ENABLE_NO_SHOW_PROTECTION is on; no card is ever charged from this slice.
model ClientPaymentMethod {
  id                    String @id @default(cuid())
  clientId              String
  // Stripe PaymentMethod id (`pm_…`), attached to the client's Stripe customer.
  stripePaymentMethodId String @unique

  // Cached display metadata (never the PAN; Stripe holds the card). Nullable so a
  // row can exist before Stripe details are hydrated.
  brand    String? // e.g. "visa"
  last4    String? @db.VarChar(4)
  expMonth Int?
  expYear  Int?

  // Exactly one default per client (enforced in application code, not the DB).
  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model ClientAddress {
