// Tax-deductible expense categories for the pro Finance tab. Ordering and
// plain-English tooltips / audit-risk levels live in the app config
// (lib/finance/expenseCategories.ts) — this enum is only the persisted key.
enum ExpenseCategory {
  SUPPLIES_PRODUCTS
  TOOLS_EQUIPMENT
  BOOTH_SUITE_RENT
  SOFTWARE_APPS
  EDUCATION_TRAINING
  LICENSING_INSURANCE
  MARKETING
  MILEAGE
  HOME_OFFICE
  CLOTHING_APPEARANCE
  OTHER
}

// How an expense row got created. IMPORT sources (CosmoProf / Salon Centric)
// are the v1.5 supply-order scrape; MANUAL / RECEIPT_UPLOAD are the v1 paths.
enum ExpenseSource {
  MANUAL
  RECEIPT_UPLOAD
  COSMOPROF
  SALON_CENTRIC
}

// A single tracked business expense on the pro Finance tab. Income is derived
// from bookings (ProfessionalMonthlyAnalytics); expenses are the one thing the
// pro (or an import) enters, so they get their own table.
model ProfessionalExpense {
  id String @id @default(cuid())

  professionalId String
  professional   ProfessionalProfile @relation("ProExpenses", fields: [professionalId], references: [id], onDelete: Cascade)

  category ExpenseCategory
  source   ExpenseSource   @default(MANUAL)

  // Money stored as cents so Finance reads avoid Decimal math (matches
  // ProfessionalMonthlyAnalytics revenue columns + lib/money helpers).
  amountCents Int

  label String
  notes String?

  // The day the expense was incurred, chosen by the pro. Written as the
  // start-of-day UTC instant for the picked calendar date in the pro's
  // timezone. Used for display ("Apr 3") and sort order.
  spentAt DateTime

  // Calendar month (pro's timezone) this expense is filed under, e.g. "2026-04".
  // Frozen at write time from spentAt + tz — matches the monthKey convention on
  // ProfessionalMonthlyAnalytics and keeps month grouping cheap and stable even
  // if the pro later changes their timezone.
  monthKey String @db.VarChar(7)

  // For MILEAGE expenses only: the logged business miles. `amountCents` is the
  // computed deduction (miles × the tax year's IRS standard rate, snapshotted
  // server-side at write time). Null for every non-mileage expense.
  mileageMiles Decimal? @db.Decimal(9, 1)

  // Optional receipt photo, reusing the existing MediaAsset upload pipeline.
  // SetNull (not Cascade): deleting the image must not delete the expense row.
  receiptMediaId String?
  receiptMedia   MediaAsset? @relation("ExpenseReceipt", fields: [receiptMediaId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([professionalId, monthKey, spentAt])
  @@index([professionalId, category, monthKey])
  @@index([receiptMediaId])
}

// How a receipt reached the pro's inbox. UPLOAD = manual photo/PDF; EMAIL =
// forwarded to their <handle>@tovis.me address; COSMOPROF / SALON_CENTRIC = a
// recognized vendor order confirmation (still arrives via EMAIL, tagged for UI).
enum ReceiptSource {
  UPLOAD
  EMAIL
  COSMOPROF
  SALON_CENTRIC
}

enum ReceiptStatus {
  PENDING
  CONFIRMED
  DISMISSED
}

// A captured receipt awaiting the pro's review. Parsing (email/OCR) is
// unreliable, so nothing becomes a ProfessionalExpense until the pro confirms —
// this table is the review queue. On confirm we mint an expense and link it.
model ProfessionalReceiptInbox {
  id String @id @default(cuid())

  professionalId String
  professional   ProfessionalProfile @relation("ProReceiptInbox", fields: [professionalId], references: [id], onDelete: Cascade)

  source ReceiptSource
  status ReceiptStatus @default(PENDING)

  // Best-effort parsed hints (may be null → the pro fills them on confirm).
  parsedAmountCents Int?
  parsedVendor      String?
  parsedDate        DateTime?

  // Provenance for email-sourced items.
  emailFrom    String?
  emailSubject String?
  receivedAt   DateTime @default(now())

  // The original receipt image/PDF, via the existing MediaAsset pipeline.
  // SetNull: deleting the media must not delete the inbox row.
  receiptMediaId String?
  receiptMedia   MediaAsset? @relation("ReceiptInboxMedia", fields: [receiptMediaId], references: [id], onDelete: SetNull)

  // Set once confirmed → the expense this receipt produced.
  createdExpenseId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([professionalId, status, receivedAt])
  @@index([receiptMediaId])
}

model ProfessionalPaymentSettings {
  id             String @id @default(cuid())
  professionalId String @unique

  collectPaymentAt PaymentCollectionTiming @default(AFTER_SERVICE)

  acceptCash       Boolean @default(true)
  acceptCardOnFile Boolean @default(false)
  acceptTapToPay   Boolean @default(false)
  acceptVenmo      Boolean @default(false)
  acceptZelle      Boolean @default(false)
  acceptAppleCash  Boolean @default(false)
  acceptPaypal     Boolean @default(false)
  acceptApplePay   Boolean @default(false)

  // New Stripe / card payment support
  acceptStripeCard Boolean @default(false)

  stripeAccountId                 String?             @unique
  stripeAccountStatus             StripeAccountStatus @default(NOT_STARTED)
  stripeChargesEnabled            Boolean             @default(false)
  stripePayoutsEnabled            Boolean             @default(false)
  stripeDetailsSubmitted          Boolean             @default(false)
  stripeRequirementsCurrentlyDue  Json?
  stripeRequirementsEventuallyDue Json?
  stripeOnboardingStartedAt       DateTime?
  stripeOnboardingCompletedAt     DateTime?
  stripeAccountUpdatedAt          DateTime?

  tipsEnabled    Boolean @default(true)
  allowCustomTip Boolean @default(true)
  tipSuggestions Json?

  // Deposits (opt-in). When enabled, qualifying clients (see depositScope) must
  // leave a deposit, captured up front via Stripe and credited toward the final
  // total. The one-time platform discovery fee rides on top of new-via-discovery
  // deposits only — see lib/booking/discoveryFee.ts.
  depositEnabled    Boolean      @default(false)
  depositType       DepositType  @default(FLAT)
  depositFlatAmount Decimal?     @db.Decimal(10, 2)
  depositPercent    Int?
  depositScope      DepositScope @default(NEW_DISCOVERY_ONLY)

  venmoHandle     String?
  zelleHandle     String?
  appleCashHandle String?
  paypalHandle    String?
  paymentNote     String?

  referralRewardEnabled   Boolean            @default(false)
  referralRewardTier      ReferralRewardTier @default(RECOGNITION)
  referralDiscountPercent Int?
  referralCreditAmount    Decimal?           @db.Decimal(10, 2)

