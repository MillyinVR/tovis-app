  updatedAt DateTime @updatedAt

  professional ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([professionalId])
  @@index([stripeAccountId])
  @@index([stripeAccountStatus])
}

/// How a pro's no-show / late-cancel fee is computed. Mirrors DepositType.
enum NoShowFeeType {
  FLAT // a fixed dollar amount (feeFlatAmount)
  PERCENT // a percentage of the booking total (feePercent, 1–100)
}

/// Which event triggered a booking's no-show / late-cancel fee.
enum NoShowFeeReason {
  NO_SHOW // pro marked the booking as a no-show
  LATE_CANCEL // client cancelled inside the pro's cancel window
}

/// Outcome of a no-show / late-cancel fee off-session charge. Recorded on the
/// Booking so the client and pro can see whether the saved card was actually
/// billed. Phase 2 revenue protection; inert unless ENABLE_NO_SHOW_PROTECTION.
enum NoShowFeeStatus {
  // Fee was owed but no charge was attempted (e.g. client had no card on file).
  SKIPPED
  CHARGED // off-session PaymentIntent succeeded
  FAILED // Stripe declined / authentication required off-session
  WAIVED // pro/admin forgave the fee after the fact
}

/// Per-pro (account-level) no-show / late-cancel fee policy (Phase 2 revenue
/// protection). One row per professional; created lazily on first save. Inert
/// unless ENABLE_NO_SHOW_PROTECTION is on — nothing charges a card while the
/// flag is dark. The fee is charged off-session against the client's default
/// saved card and routed to the pro's connected account, mirroring the
/// destination charge on client checkout.
model ProNoShowSettings {
  id             String @id @default(cuid())
  professionalId String @unique

  // Master opt-in. While false the pro never charges a no-show/late-cancel fee.
  enabled Boolean @default(false)

  // Fee shape (pro's choice: flat dollar amount or percent of booking total).
  feeType       NoShowFeeType @default(FLAT)
  feeFlatAmount Decimal?      @db.Decimal(10, 2)
  feePercent    Int? // 1–100 when feeType = PERCENT

  // Hours before the scheduled start inside which a client cancellation counts
  // as a "late cancel" and is billable. Locked to 24 at launch; stored so the
  // window is configurable later without a migration.
  cancelWindowHours Int @default(24)

  // Which events actually bill: a pro-marked no-show, and/or a client cancel
  // inside the window. Both default on when the pro opts in.
  chargeNoShow     Boolean @default(true)
  chargeLateCancel Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  professional ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([professionalId])
}

/// Per-pro (account-level) appointment-reminder cadence. One row per pro,
/// created lazily on first save. Configures WHICH client reminders fire ahead of
/// a booking; each value in `offsetDays` schedules one reminder that many days
/// before the appointment (7 = one week, 3 = three days, 1 = day before). The
/// scheduling spine (lib/notifications/appointmentReminders.ts) reads this to
/// plan reminders on the shared ScheduledClientNotification queue; quiet-hours
/// and dedupe are handled downstream by the dispatch layer. Missing row => the
/// default cadence below applies, so reminders keep working without a saved row.
model ProReminderSettings {
  id             String @id @default(cuid())
  professionalId String @unique

  // Master opt-in. While false, no appointment reminders are scheduled for this
  // pro's bookings. Reminders default ON so every pro sends them out of the box.
  enabled Boolean @default(true)

  // Lead times (minutes before the appointment) to send a reminder at. Any lead
  // is allowed — a whole-day lead is a multiple of 1440 and fires at the
  // appointment's own local wall-clock time N days earlier (DST-safe); a sub-day
  // lead fires exactly that many minutes before the appointment instant. Bounds
  // (min/max/granularity/count) are enforced in lib/reminderSettings/settings.ts.
  // Default cadence: one week + three days + day before (10080 / 4320 / 1440).
  offsetMinutes Int[] @default([10080, 4320, 1440])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  professional ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([professionalId])
}

// Catalog of membership tiers (Free / Pro / Studio). Pricing + Stripe Billing IDs
// live here; the entitlement matrix that actually gates features is code-defined in
// lib/pro/entitlements.ts (keyed by `key`), so gating works without seeded rows.
model SubscriptionPlan {
  id              String   @id @default(cuid())
  key             String   @unique // "free" | "pro" | "studio"
  name            String
  priceCents      Int      @default(0)
  interval        String? // "month" | "year" — null for free
  stripeProductId String?
  stripePriceId   String? // null for free
  features        Json? // display copy; NOT the gating source of truth
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// A pro's current membership. Missing row => free plan. The Billing customer id is
// DISTINCT from the Connect account id on ProfessionalPaymentSettings — a pro is both
// a connected account (receives client money) and a customer (pays Tovis).
model ProfessionalSubscription {
  id             String @id @default(cuid())
  professionalId String @unique

  planKey String             @default("free")
  status  SubscriptionStatus @default(ACTIVE)

  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  trialEndsAt          DateTime?

  // Admin-granted complimentary membership ("free months"). Lives BESIDE the
  // paid Stripe state — webhooks never write these fields, so a comp survives
  // real-subscription churn. Entitlements resolve to the better of paid vs
  // comp while compUntil is in the future; the comp-expiry job clears expired
  // comps and recomputes the isPremium backfill.
  compPlanKey         String?
  compUntil           DateTime?
  compNote            String?
  compGrantedByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  professional ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([planKey])
  @@index([status])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@index([compUntil])
}

model ProfessionalLocation {
  id             String @id @default(cuid())
  professionalId String

  type       ProfessionalLocationType
  name       String?
  isPrimary  Boolean                  @default(false)
  isBookable Boolean                  @default(true)

  // Address (SALON/SUITE required; MOBILE_BASE optional)
  formattedAddress String?
  addressLine1     String?
  addressLine2     String?
  city             String?
  state            String?
  postalCode       String?
  countryCode      String?
  placeId          String?

  // Geo
  lat Decimal? @db.Decimal(10, 7)
  lng Decimal? @db.Decimal(10, 7)

  // Address encryption expansion fields.
  // Keep raw fields during expand/dual-write/backfill phase.
  encryptedAddressJson Json?
  addressKeyVersion    String?   @db.VarChar(32)
  postalCodePrefix     String?   @db.VarChar(12)
  latApprox            Decimal?  @db.Decimal(8, 4)
  lngApprox            Decimal?  @db.Decimal(8, 4)
  encryptedAt          DateTime?

  // ✅ Source of truth for booking timezone
  timeZone String? @db.VarChar(64)

  // ✅ Source of truth for calendar hours
  // { "mon": { "enabled": true, "start": "09:00", "end": "17:00" }, ... }
  workingHours Json

  // Location-level booking defaults
  bufferMinutes        Int @default(15)
  stepMinutes          Int @default(30)
  advanceNoticeMinutes Int @default(15)
  maxDaysAhead         Int @default(365)

  // Soft-delete. A pro can "remove" a location even when historical bookings
  // still reference it (FK is Restrict). Referenced locations are archived
  // (hidden everywhere the pro manages/publishes/books) rather than hard-deleted
  // so booking history and FK integrity are preserved. Locations with no
  // references are hard-deleted and never get an archivedAt.
  archivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  professional ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  bookings           Booking[]
  holds              BookingHold[]
  blocks             CalendarBlock[]
  lastMinuteOpenings LastMinuteOpening[]

  searchIndexEntry ProfessionalSearchIndex?

  aftercareRebookSlots AftercareRebookSlot[]
  waitlistOffers       WaitlistOffer[]

  @@index([placeId])
  @@index([professionalId])
  @@index([professionalId, isPrimary])
  @@index([professionalId, isBookable])
  @@index([professionalId, archivedAt])
  @@index([lat, lng])
  @@index([isBookable, type, lat, lng])
  @@index([postalCodePrefix])
  @@index([latApprox, lngApprox])
  @@index([addressKeyVersion])
}

// P2.4a foundation — denormalized search/discovery index.
//
// One row per ProfessionalLocation; refreshed by hooks in mutation
// routes (locations, working-hours, offerings) via
// `lib/search/index/refreshSearchIndex.ts`. The `geom` column is a
// PostGIS `geography(Point, 4326)` — Prisma cannot model it natively,
// so all upserts go through raw SQL helpers. Reads via the typed
// Prisma client work for every column EXCEPT `geom`; geo radius
// queries use raw SQL with `ST_DWithin`.
//
// This table is dark-loaded in P2.4a — population happens on every
// mutation, but `searchPros` and `loadNearbyPros` still query the
// source tables. P2.4b will swap the read paths to this index.
model ProfessionalSearchIndex {
  // 1:1 with a ProfessionalLocation (PK + FK).
  locationId     String @id
  professionalId String

  // Geography column — created by raw SQL in the migration; written
  // exclusively via $executeRaw in refreshLocation/refreshProfessional.
  // Typed Prisma writes against this column will throw at runtime.
  geom Unsupported("geography(Point, 4326)")
  lat  Decimal                               @db.Decimal(10, 7)
  lng  Decimal                               @db.Decimal(10, 7)

  // Pro-level filter columns (denormalized from ProfessionalProfile).
  verificationStatus VerificationStatus
  professionType     ProfessionType?
  businessName       String?
  // Pre-resolved public display name (honors ProfessionalProfile.nameDisplay),
  // written by refreshSearchIndex so search results don't re-resolve per row.
  displayName        String?
  handle             String?
  handleNormalized   String?
  avatarUrl          String?
  mobileRadiusMiles  Int?

  // Location-level filter columns (denormalized from ProfessionalLocation).
  locationType     ProfessionalLocationType
  isPrimary        Boolean
  isBookable       Boolean
  city             String?
  state            String?
  formattedAddress String?
  timeZone         String?
  workingHours     Json

  // Offering rollups (denormalized from ProfessionalServiceOffering joined to Service).
  // Arrays enable GIN-indexed `category_id = ANY(category_ids)` filters.
  categoryIds    String[]
  serviceIds     String[]
  offersInSalon  Boolean  @default(false)
  offersMobile   Boolean  @default(false)
  minSalonPrice  Decimal? @db.Decimal(10, 2)
  minMobilePrice Decimal? @db.Decimal(10, 2)
  minAnyPrice    Decimal? @db.Decimal(10, 2)

  // Rating rollup (denormalized from Review.groupBy).
  ratingAvg   Float?
  ratingCount Int    @default(0)

  // Bookkeeping for debugging stale rows.
  refreshedAt   DateTime @default(now()) @updatedAt
  refreshSource String?

  professional ProfessionalProfile  @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  location     ProfessionalLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  // GIST and GIN indexes are created in raw SQL in the migration.

  @@index([professionalId])
  @@index([verificationStatus, isBookable])
}

model AdminActionLog {
