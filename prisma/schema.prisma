model ServiceCategory {
  id               String            @id @default(cuid())
  name             String
  slug             String            @unique
  description      String?
  parentId         String?
  adminPermissions AdminPermission[]

  parent   ServiceCategory?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children ServiceCategory[] @relation("CategoryChildren")

  isActive Boolean @default(true)

  viralRequests   ViralServiceRequest[]
  services        Service[]
  adminActionLogs AdminActionLog[]      @relation("CategoryLogs")
  lookRankStat    LookCategoryRankStat?
}

// Per-service-category engagement-rate aggregate — the data source for the
// per-category Bayesian prior in Look rank scoring (personalization spec §4.1:
// regress thin-evidence looks toward "typical for THIS category", not the
// global constant). One row per category with eligible looks, refreshed by the
// daily looks-category-rank-stats job and the recompute sweep script; consumed
// via lib/looks/categoryRankStats.ts.
model LookCategoryRankStat {
  categoryId         String   @id
  // Sums over eligible (published + approved) looks in the category:
  // intent-weighted engagement (the rate numerator) and floored impressions
  // (the denominator — per-look GREATEST(viewCount, raw engagement), the same
