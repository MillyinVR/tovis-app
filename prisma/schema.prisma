model Board {
  id             String          @id @default(cuid())
  clientId       String
  name           String
  // URL-safe handle for the public (SHARED) board page /u/[handle]/boards/[slug].
  // Derived from `name` on write; unique per client (social-first D3).
  slug           String
  visibility     BoardVisibility @default(PRIVATE)
  // Personalization context, captured once at board creation and freely
  // editable after (personalization spec §7–8). `type` says what the board is
  // for; `eventDate` is the calendar date it counts down to (bridal/prom — a
  // Postgres DATE, so no time-of-day/timezone semantics); `answers` holds the
  // skippable creation-question chips, validated against the question sets in
  // lib/boards/context.ts. type + eventDate feed the personalized-feed occasion boost;
  // answers are stored for the board-feed scoring pass (§4.4) and the
  // self-profile write-through (§6.6). Owner-only — never exposed on the
  // public board page.
  type           BoardType       @default(GENERAL)
  eventDate      DateTime?       @db.Date
  answers        Json?
  // Admin moderation flag for a SHARED board: when set, the public board page +
  // share surfaces 404 (owner keeps their private copy). Plain TEXT admin id —
  // no FK/back-relation, mirroring LookPost.featuredByUserId (social-first D3).
  hiddenAt       DateTime?
  hiddenByUserId String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  client ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items  BoardItem[]

  // Per-board local visual taste vector (personalization spec §6.0/§6.1) —
  // decayed average of the embeddings of this board's saved looks.
  tasteVector BoardTasteVector?

  @@unique([clientId, name])
  @@unique([clientId, slug])
  @@index([clientId, createdAt])
}

model BoardItem {
  id         String   @id @default(cuid())
  boardId    String
  lookPostId String
  createdAt  DateTime @default(now())

  board    Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  lookPost LookPost @relation(fields: [lookPostId], references: [id], onDelete: Cascade)

  @@unique([boardId, lookPostId])
  @@index([lookPostId, createdAt])
  @@index([boardId, createdAt])
}

// ==========================================
// PERSONALIZATION — VISUAL EMBEDDINGS (§6.0)
// ==========================================
//
// pgvector-backed tables for the visual-taste layer of the personalization
// spec. All `embedding` columns are Unsupported("vector(1024)") — Prisma's
// typed client can neither read nor write them (same constraint as
// ProfessionalSearchIndex.geom); every embedding read/write goes through raw
// SQL in lib/personalization/lookEmbeddingStore.ts / tasteVectors.ts. The
// vector dimension is pinned by LOOK_EMBEDDING_DIMENSIONS in
// lib/personalization/lookEmbedding.ts — the two must move together.
// `updatedAt`/`computedAt` carry DB defaults instead of @updatedAt because the
// raw-SQL writers maintain them explicitly.

// One embedding per look — the §6.0 "embed at upload" corpus. `model` records
// which provider model produced the vector and `mediaAssetId` which asset was
// embedded, so a model upgrade or primary-image swap makes the row detectably
// stale (the embed job + backfill re-embed on mismatch).
model LookPostEmbedding {
  lookPostId   String                      @id
  embedding    Unsupported("vector(1024)")
  model        String
  mediaAssetId String
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @default(now())

  lookPost LookPost @relation(fields: [lookPostId], references: [id], onDelete: Cascade)

  @@index([model])
}

// Per-look, per-source, per-day impression aggregate (spec §5.6 anti-gaming
// groundwork). LookPost.viewCount stays the lifetime rate denominator (§4.1);
// this table breaks the same sampled impressions down by source and daily
// window so a velocity-anomaly check (step 14) can spot engagement that spikes
// far outside its matching impression baseline. Written only by the
// APPLY_LOOK_VIEWS job — one upsert per (look, source) it touches, incrementing
// `count`. `windowDate` is stamped server-side from job-run time (UTC day):
// impressions are sampled/best-effort so the client is never trusted with the
// window. This data is time-sensitive and cannot be backfilled — hence captured
// now, ahead of its step-14 reader.
model LookPostImpressionStat {
  lookPostId String
  source     LookImpressionSource
  windowDate DateTime             @db.Date
  count      Int                  @default(0)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  lookPost LookPost @relation(fields: [lookPostId], references: [id], onDelete: Cascade)

  @@id([lookPostId, source, windowDate])
  @@index([windowDate])
  @@index([lookPostId, windowDate])
}

// Global taste vector per client (§6.0/§6.1 global_taste_embedding): the
// decayed, signal-weighted average of the embeddings of looks the client
// liked/saved. Recomputed from scratch by the taste-vectors job — never
// incrementally mutated — so decay stays exact.
model ClientTasteVector {
  clientProfileId String                      @id
  embedding       Unsupported("vector(1024)")
  model           String
  // How many embedded like/save signals contributed — a confidence signal for
  // ranking consumers (a 2-signal vector should steer less than a 50-signal one).
  signalCount     Int
  computedAt      DateTime                    @default(now())
  createdAt       DateTime                    @default(now())

  client ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
}

// Per-board local taste vector (§6.1 board_contexts.local_taste_embedding):
// the decayed average of the embeddings of the board's saved looks. Kept
// separate from the global vector so boards feel personal (spec §6.2 keeps
// board→global bleed one-directional and small).
model BoardTasteVector {
  boardId     String                      @id
  embedding   Unsupported("vector(1024)")
  model       String
  signalCount Int
  computedAt  DateTime                    @default(now())
  createdAt   DateTime                    @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
}

// =======================
// WAITLIST
// =======================

model WaitlistEntry {
  id             String  @id @default(cuid())
  clientId       String
  professionalId String
  serviceId      String
  mediaId        String?
  notes          String?

  preferenceType WaitlistPreferenceType @default(ANY_TIME)
  specificDate   DateTime?              @db.Date
  timeOfDay      WaitlistTimeOfDay?
  windowStartMin Int?
  windowEndMin   Int?

  status    WaitlistStatus @default(ACTIVE)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  client       ClientProfile       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  professional ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service      Service             @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  media        MediaAsset?         @relation(fields: [mediaId], references: [id], onDelete: SetNull)

  messageThread MessageThread?  @relation("WaitlistThread")
  offers        WaitlistOffer[]

  @@index([professionalId, status, createdAt])
  @@index([clientId, status, createdAt])
  @@index([serviceId, status, createdAt])
  @@index([professionalId, preferenceType, status])
}

// A pro-proposed appointment time for a waitlisted client, awaiting the client's
// Confirm/Decline (the true client-confirm gate for the waitlist "Offer a time"
// flow). Mirrors the aftercare BOOKED_NEXT_APPOINTMENT proposal, but is scoped to
// a WaitlistEntry instead of a completed source booking. On Confirm this
// materializes a normal ACCEPTED booking via performLockedCreateProBooking.
//
// A partial unique index (status = 'PENDING') enforces at most one outstanding
// offer per entry — added by raw SQL in the migration (Prisma can't express a
// partial unique index).
model WaitlistOffer {
  id String @id @default(cuid())

  waitlistEntryId String
  waitlistEntry   WaitlistEntry @relation(fields: [waitlistEntryId], references: [id], onDelete: Cascade)

  professionalId String
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  clientId String
  client   ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)

  offeringId String
  offering   ProfessionalServiceOffering @relation(fields: [offeringId], references: [id], onDelete: Cascade)

  locationId   String
  location     ProfessionalLocation @relation(fields: [locationId], references: [id], onDelete: Restrict)
  locationType ServiceLocationType

  startsAt        DateTime
  endsAt          DateTime
  durationMinutes Int

  status    WaitlistOfferStatus @default(PENDING)
  expiresAt DateTime?

  // Set when the client confirms → the booking this offer materialized.
  bookingId String?  @unique
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  respondedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([waitlistEntryId, status])
  @@index([clientId, status, createdAt])
  @@index([professionalId, status, createdAt])
  @@index([offeringId])
  @@index([locationId])
}

model MessageThread {
  id             String @id @default(cuid())
  clientId       String
  professionalId String

  // ✅ context-scoped
  contextType MessageThreadContextType
  contextId   String // bookingId OR serviceId OR offeringId OR professionalId OR waitlistEntryId

  // Optional pointers for convenience.
  // These make joins explicit while contextType/contextId remains the canonical uniqueness guard.
  bookingId       String?        @unique
  booking         Booking?       @relation("BookingThreads", fields: [bookingId], references: [id], onDelete: SetNull)
  serviceId       String?
  offeringId      String?
  waitlistEntryId String?        @unique
  waitlistEntry   WaitlistEntry? @relation("WaitlistThread", fields: [waitlistEntryId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // quick inbox sorting / preview (optional but recommended)
  lastMessageAt      DateTime?
  lastMessagePreview String?

  client       ClientProfile       @relation("ClientThreads", fields: [clientId], references: [id])
  professional ProfessionalProfile @relation("ProThreads", fields: [professionalId], references: [id])

  service  Service?                     @relation("ServiceThreads", fields: [serviceId], references: [id])
  offering ProfessionalServiceOffering? @relation("OfferingThreads", fields: [offeringId], references: [id])

  messages Message[]
  quotes   Quote[]

  participants MessageThreadParticipant[]

  @@unique([clientId, professionalId, contextType, contextId])
  @@index([professionalId, updatedAt])
  @@index([clientId, updatedAt])
  @@index([professionalId, contextType, lastMessageAt])
  @@index([clientId, contextType, lastMessageAt])
  @@index([contextType, contextId])
  @@index([waitlistEntryId])
}

model MessageThreadParticipant {
  id         String    @id @default(cuid())
  threadId   String
  userId     String
  role       Role
  lastReadAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  thread MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User          @relation("UserThreadParticipants", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@index([userId, updatedAt])
  @@index([threadId, updatedAt])
}

model Message {
  id           String   @id @default(cuid())
  threadId     String
  senderUserId String
  body         String?
  createdAt    DateTime @default(now())

  thread MessageThread @relation(fields: [threadId], references: [id])
  sender User          @relation("UserSentMessages", fields: [senderUserId], references: [id])

  attachments MessageAttachment[]

  @@index([threadId, createdAt])
}

model MessageAttachment {
  id        String @id @default(cuid())
  messageId String

  // Storage pointer for a private (media-private) attachment. The bytes are
  // never world-readable; the thread read routes sign a short-lived URL from
  // (storageBucket, storagePath) at fetch time. `url` is a legacy/optional
  // fallback for any directly-renderable (public) URL — private attachments
  // leave it null and rely on the pointer above.
  url           String?
  storageBucket String?
  storagePath   String?

  mediaType MediaType @default(IMAGE)
  createdAt DateTime  @default(now())

  message Message @relation(fields: [messageId], references: [id])
}

model Quote {
  id              String              @id @default(cuid())
  threadId        String
  serviceId       String
  offeringId      String?
  locationType    ServiceLocationType
  priceStartingAt Decimal?            @db.Decimal(10, 2)
  durationMinutes Int?
  notes           String?
  status          String              @default("SENT")
  createdAt       DateTime            @default(now())

  thread   MessageThread                @relation(fields: [threadId], references: [id])
  service  Service                      @relation("ServiceQuotes", fields: [serviceId], references: [id])
  offering ProfessionalServiceOffering? @relation("OfferingQuotes", fields: [offeringId], references: [id])
}

model BookingConsultation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  // What the pro proposed
  proposedServicesJson Json?
  proposedPrice        Decimal?
  notes                String?

  // Client decision
  clientApprovedAt DateTime?
  clientDeclinedAt DateTime?
  clientMessage    String?
}

model ClientNotification {
  id       String @id @default(cuid())
  clientId String

  // what happened
  eventKey NotificationEventKey
  title    String
  body     String?

  // linking / deep link support
  href        String  @default("")
  bookingId   String?
  aftercareId String?

  // structured metadata for notification-specific context
  data Json?

  // dedupe should be per client, not global across the whole app
  dedupeKey String?

  // read state
  readAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt

  client     ClientProfile          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  booking    Booking?               @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  aftercare  AftercareSummary?      @relation(fields: [aftercareId], references: [id], onDelete: SetNull)
  dispatches NotificationDispatch[] @relation("ClientInboxNotificationDispatches")

  @@unique([clientId, dedupeKey])
  @@index([clientId, createdAt])
  @@index([clientId, readAt])
  @@index([clientId, eventKey, createdAt])
  @@index([bookingId])
  @@index([aftercareId])
}

model ScheduledClientNotification {
  id        String  @id @default(cuid())
  clientId  String
  bookingId String?

  eventKey NotificationEventKey
  runAt    DateTime
  href     String               @default("")

  // structured metadata used to render the final notification
  data Json?

  dedupeKey String?

  processedAt DateTime?
  cancelledAt DateTime?
  failedAt    DateTime?
  lastError   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  client  ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  booking Booking?      @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@unique([clientId, dedupeKey])
  @@index([processedAt, cancelledAt, runAt])
  @@index([clientId, runAt])
  @@index([bookingId, runAt])
}

model BookingServiceItem {
  id         String  @id @default(cuid())
  bookingId  String
  serviceId  String
  offeringId String? // base offering or add-on offering (optional)

  // ✅ NEW: classify item
  itemType BookingServiceItemType @default(BASE)

  // ✅ NEW: if this item was chosen as an add-on of a base item
  parentItemId String?
  parentItem   BookingServiceItem?  @relation("BookingServiceItemParent", fields: [parentItemId], references: [id], onDelete: SetNull)
  children     BookingServiceItem[] @relation("BookingServiceItemParent")

  // Snapshots at the time of booking
  priceSnapshot           Decimal @db.Decimal(10, 2)
  durationMinutesSnapshot Int

  // Optional: ordering + notes
  sortOrder Int      @default(0)
  notes     String?
  createdAt DateTime @default(now())

  booking  Booking                      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service  Service                      @relation(fields: [serviceId], references: [id])
  offering ProfessionalServiceOffering? @relation(fields: [offeringId], references: [id])

  @@index([bookingId])
  @@index([serviceId])
  @@index([bookingId, sortOrder])
  @@index([bookingId, itemType])
  @@index([parentItemId])
}

model CalendarBlock {
  id             String  @id @default(cuid())
  professionalId String
  locationId     String? // null = blocks all locations (rare, but useful)

  startsAt DateTime
  endsAt   DateTime
  note     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  professionalProfile ProfessionalProfile   @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  location            ProfessionalLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@index([locationId])
  @@index([professionalId, startsAt])
  @@index([professionalId, endsAt])
  @@index([professionalId, locationId, startsAt, endsAt])
}

model NfcCard {
  id   String      @id @default(cuid()) // this is what’s encoded in the NFC URL
  type NfcCardType

  // “ownership” (never changes once claimed)
  claimedAt       DateTime?
  claimedByUserId String?
  claimedByUser   User?     @relation(fields: [claimedByUserId], references: [id])

  // referral attribution (for future rewards)
  referralCount Int @default(0)

  // pro booking cards
  professionalId String?
  professional   ProfessionalProfile? @relation(fields: [professionalId], references: [id])

  // Issuing tenant (contract phase: required; root tenant for standard
  // cards, the white-label tenant for SALON_WHITE_LABEL cards).
  tenantId String
  tenant   Tenant @relation("TenantNfcCards", fields: [tenantId], references: [id], onDelete: Restrict)

  isActive          Boolean            @default(true)
  shortCode         String             @unique
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  tapIntents        TapIntent[]
  attributionEvents AttributionEvent[]
  referrals         Referral[]

  @@index([type])
  @@index([claimedByUserId])
  @@index([professionalId])
  @@index([tenantId])
}

model TapIntent {
  id     String  @id @default(cuid())
  cardId String
  card   NfcCard @relation(fields: [cardId], references: [id])

  // who it eventually belongs to (set after login/signup)
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  // what the user was trying to do
  intentType  String // "SIGNUP_CLIENT" | "SIGNUP_PRO" | "BOOK_PRO" | "WL_SIGNUP" etc.
  payloadJson Json?

  // anti-abuse + cleanup
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([cardId])
  @@index([userId])
  @@index([expiresAt])
}

model AttributionEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  eventType String

  cardId String?
  card   NfcCard? @relation(fields: [cardId], references: [id])

  actorUserId String?
  actorUser   User?   @relation("AttributionActor", fields: [actorUserId], references: [id])

  creditedUserId String?
  creditedUser   User?   @relation("AttributionCredited", fields: [creditedUserId], references: [id])

  metaJson Json?

  @@index([cardId])
  @@index([actorUserId])
  @@index([creditedUserId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int       @default(0)
  createdAt DateTime  @default(now())

  // Optional: nice for auditing / abuse detection
  ip        String?
  userAgent String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model SupportTicket {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdByUserId String?
  createdByRole   String? // "CLIENT" | "PRO" | "GUEST" (store as string to avoid enum coupling)

  subject String
  message String
  status  SupportTicketStatus @default(OPEN)

  // Optional admin handling
  handledByAdminId String?
  handledAt        DateTime?

  // Optional relations if you want them later
  createdByUser  User? @relation("SupportTicketCreatedBy", fields: [createdByUserId], references: [id])
  handledByAdmin User? @relation("SupportTicketHandledBy", fields: [handledByAdminId], references: [id])

  @@index([status, createdAt])
  @@index([createdByUserId, createdAt])
}

model ReviewHelpful {
  id        String   @id @default(cuid())
  reviewId  String
  userId    String
  createdAt DateTime @default(now())

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
  @@index([reviewId, createdAt])
  @@index([userId, createdAt])
}

model ServiceFavorite {
  id        String   @id @default(cuid())
  serviceId String
  userId    String
  createdAt DateTime @default(now())

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([serviceId, userId])
  @@index([userId, createdAt])
  @@index([serviceId, createdAt])
}

model ViralServiceRequest {
  id            String  @id @default(cuid())
  clientId      String
  name          String
  description   String?
  sourceUrl     String?
  linksJson     Json?
  mediaUrlsJson Json?

  requestedCategoryId String?
  requestedCategory   ServiceCategory? @relation(fields: [requestedCategoryId], references: [id], onDelete: SetNull)

  status           ViralServiceRequestStatus @default(REQUESTED)
  moderationStatus ModerationStatus          @default(APPROVED)

  reviewedAt       DateTime?
  reviewedByUserId String?
  removedAt        DateTime?
  reportCount      Int       @default(0)
  approvedAt       DateTime?
  rejectedAt       DateTime?
  adminNotes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client          ClientProfile                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  reviewedByUser  User?                        @relation("ViralServiceRequestReviewedByUser", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  reports         ViralServiceRequestReport[]
  approvalFanOuts ViralRequestApprovalFanOut[]

  @@index([clientId, createdAt])
  @@index([status, createdAt])
  @@index([requestedCategoryId, status, createdAt])
  @@index([moderationStatus, reportCount, createdAt])
  @@index([reviewedByUserId, reviewedAt])
}

model Referral {
  id String @id @default(cuid())

  referrerClientId String
  referrerClient   ClientProfile @relation("ReferrerReferrals", fields: [referrerClientId], references: [id])

  referredClientId String
  referredClient   ClientProfile @relation("ReferredReferrals", fields: [referredClientId], references: [id])

  nfcCardId String?
  nfcCard   NfcCard? @relation(fields: [nfcCardId], references: [id])

  status    ReferralStatus @default(PENDING)
  expiresAt DateTime

  confirmedAt DateTime?

  convertedAt      DateTime?
  triggerBookingId String?              @unique
  triggerBooking   Booking?             @relation("ReferralTriggerBooking", fields: [triggerBookingId], references: [id])
  professionalId   String?
  professional     ProfessionalProfile? @relation(fields: [professionalId], references: [id])

  rewardTier  ReferralRewardTier?
  rewardValue Decimal?            @db.Decimal(10, 2)

  rewardAppliedAt DateTime?
  rewardBookingId String?   @unique
  rewardBooking   Booking?  @relation("ReferralRewardBooking", fields: [rewardBookingId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([referrerClientId, status])
  @@index([referredClientId, status])
  @@index([professionalId, status])
  @@index([nfcCardId])
}
