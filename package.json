{
  "name": "tovis-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "postinstall": "prisma generate && (git config core.hooksPath .githooks 2>/dev/null || true)",
    "dev": "prisma generate && next dev",
    "dev:test-db": "prisma generate && DATABASE_URL=postgresql://postgres:postgres@localhost:5433/tovis_test DIRECT_URL=postgresql://postgres:postgres@localhost:5433/tovis_test next dev",
    "dev:loadtest": "prisma generate && LOAD_TEST_DISABLE_REAL_DELIVERY=1 DATABASE_URL=postgresql://postgres:postgres@localhost:5434/tovis_dev DIRECT_URL=postgresql://postgres:postgres@localhost:5434/tovis_dev next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "typecheck": "prisma generate && tsc --noEmit",
    "seed": "ALLOW_SEED_SCRIPT=1 CONFIRM_NON_PRODUCTION_DB=1 node prisma/seed.cjs",
    "seed:dev": "ALLOW_SEED_SCRIPT=1 CONFIRM_NON_PRODUCTION_DB=1 node prisma/seed.cjs",
    "seed:test": "DATABASE_URL=postgresql://postgres:postgres@localhost:5433/tovis_test DIRECT_URL=postgresql://postgres:postgres@localhost:5433/tovis_test ALLOW_SEED_SCRIPT=1 CONFIRM_NON_PRODUCTION_DB=1 node prisma/seed.cjs",
    "prisma:studio:test": "DATABASE_URL=postgresql://postgres:postgres@localhost:5433/tovis_test DIRECT_URL=postgresql://postgres:postgres@localhost:5433/tovis_test prisma studio",
    "test": "vitest run --config vitest.config.mts",
    "test:watch": "vitest --config vitest.config.mts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:install": "playwright install --with-deps",
    "test:e2e:ci": "playwright test",
    "test:e2e:local": "dotenv -e .env.e2e.local -e .env.local -- playwright test",
    "db:test:up": "docker run --name tovis-test-postgres -e POSTGRES_PASSWORD=postgres -e POSTGRES_USER=postgres -e POSTGRES_DB=tovis_test -p 5433:5432 -d imresamu/postgis:16-3.4-bundle0",
    "db:test:extensions": "docker exec tovis-test-postgres psql -U postgres -d tovis_test -c \"CREATE EXTENSION IF NOT EXISTS vector\"",
    "db:test:start": "docker start tovis-test-postgres",
    "db:test:stop": "docker stop tovis-test-postgres",
    "db:test:down": "docker rm -f tovis-test-postgres",
    "db:guard": "node scripts/prisma-guard.cjs",
    "db:push": "node scripts/prisma-guard.cjs db push",
    "migrate:dev": "node scripts/prisma-guard.cjs migrate dev",
    "migrate:reset": "node scripts/prisma-guard.cjs migrate reset",
    "db:test:push": "pnpm db:test:extensions && node scripts/with-test-db.mjs npx prisma db push --skip-generate",
    "db:test:seed": "pnpm db:test:push && pnpm seed:test && pnpm backfill:contact-hash-v2:test",
    "db:dev:up": "docker run --name tovis-dev-postgres -e POSTGRES_PASSWORD=postgres -e POSTGRES_USER=postgres -e POSTGRES_DB=tovis_dev -p 5434:5432 -d imresamu/postgis:16-3.4-bundle0",
    "db:dev:extensions": "docker exec tovis-dev-postgres psql -U postgres -d tovis_dev -c \"CREATE EXTENSION IF NOT EXISTS vector\"",
    "db:dev:start": "docker start tovis-dev-postgres",
    "db:dev:stop": "docker stop tovis-dev-postgres",
    "db:dev:down": "docker rm -f tovis-dev-postgres",
    "db:dev:wait": "until docker exec tovis-dev-postgres pg_isready -U postgres -d tovis_dev >/dev/null 2>&1; do echo 'waiting for tovis-dev-postgres…'; sleep 1; done",
    "db:dev:push": "pnpm db:dev:extensions && DATABASE_URL=postgresql://postgres:postgres@localhost:5434/tovis_dev DIRECT_URL=postgresql://postgres:postgres@localhost:5434/tovis_dev prisma db push --skip-generate",
    "db:dev:seed": "DATABASE_URL=postgresql://postgres:postgres@localhost:5434/tovis_dev DIRECT_URL=postgresql://postgres:postgres@localhost:5434/tovis_dev ALLOW_SEED_SCRIPT=1 CONFIRM_NON_PRODUCTION_DB=1 node prisma/seed.cjs",
    "db:dev:permissions": "DATABASE_URL=postgresql://postgres:postgres@localhost:5434/tovis_dev DIRECT_URL=postgresql://postgres:postgres@localhost:5434/tovis_dev tsx scripts/importLicensePermissions.ts --write",
    "dev:mint-jwt": "tsx scripts/dev/mint-dev-jwt.ts",
    "db:dev:setup": "pnpm db:dev:wait && pnpm db:dev:push && pnpm db:dev:seed && pnpm backfill:contact-hash-v2:dev && pnpm db:dev:permissions",
    "db:dev:studio": "DATABASE_URL=postgresql://postgres:postgres@localhost:5434/tovis_dev DIRECT_URL=postgresql://postgres:postgres@localhost:5434/tovis_dev prisma studio",
    "test:integration": "node scripts/with-test-db.mjs npx vitest run --config vitest.integration.config.mts",
    "test:integration:ci": "vitest run --config vitest.integration.config.mts",
    "test:integration:booking-overlap": "node scripts/with-test-db.mjs npx vitest run tests/integration/booking-overlap-concurrency.test.ts --config vitest.integration.config.mts --maxWorkers=1 --minWorkers=1",
    "test:load:signup": "dotenv -e .env.local -- tsx tests/load/signup-load-test.ts",
    "check:booking-boundary": "node tools/check-booking-write-boundary.mjs",
    "check:media-render-boundary": "node tools/check-media-render-boundary.mjs",
    "check:consultation-canonical": "node tools/check-consultation-canonical.mjs",
    "check:lifecycle-field-writes": "node tools/check-lifecycle-field-writes.mjs",
    "check:no-type-escape": "node tools/check-no-type-escape.mjs",
    "check:canonical-normalization": "node tools/check-canonical-normalization.mjs",
    "check:pii-plaintext-reads": "node tools/check-pii-plaintext-reads.mjs",
    "check:tenant-aware-discovery": "node tools/check-tenant-aware-discovery.mjs",
    "check:no-hardcoded-brand-strings": "node tools/check-no-hardcoded-brand-strings.mjs",
    "check:no-raw-datetime-format": "node tools/check-no-raw-datetime-format.mjs",
    "check:notification-kick": "node tools/check-notification-kick.mjs",
    "check:api-schema": "node tools/check-api-schema.mjs",
    "check:ci-coverage": "node tools/check-ci-coverage.mjs",
    "gen:api-schema": "ts-json-schema-generator --path lib/dto/index.ts --type '*' --tsconfig tsconfig.json --additional-properties --out schema/api/tovis-api.schema.json",
    "proof:storage-policy": "node --env-file=.env.production.local scripts/proof-storage-policy.mjs",
    "test:chaos": "dotenv -e .env.local -- vitest run --config vitest.config.mts tests/chaos",
    "verify:launch-ops": "pnpm test:chaos && pnpm test:load:launch",
    "loadproof:fixtures": "tsx prisma/scripts/loadTestFixtures.ts",
    "check:privacy-guards": "pnpm check:canonical-normalization && pnpm check:pii-plaintext-reads",
    "check:static-guards": "pnpm check:booking-boundary && pnpm check:media-render-boundary && pnpm check:consultation-canonical && pnpm check:lifecycle-field-writes && pnpm check:no-type-escape && pnpm check:canonical-normalization && pnpm check:pii-plaintext-reads && pnpm check:tenant-aware-discovery && pnpm check:no-hardcoded-brand-strings && pnpm check:no-raw-datetime-format && pnpm check:notification-kick && pnpm check:api-schema && pnpm check:ci-coverage",
    "test:load:availability": "dotenv -e .env.local -- tsx tests/load/availability-bootstrap-load-test.ts",
    "test:load:holds": "dotenv -e .env.local -- tsx tests/load/hold-create-load-test.ts",
    "test:load:booking-finalize": "dotenv -e .env.local -- tsx tests/load/booking-finalize-load-test.ts",
    "test:load:checkout": "dotenv -e .env.local -- tsx tests/load/checkout-load-test.ts",
    "test:load:launch": "dotenv -e .env.local -- tsx tests/load/run-launch-load-suite.ts",
    "test:load:media-metadata": "dotenv -e .env.local -- tsx tests/load/media-metadata-load-test.ts",
    "test:load:notifications": "dotenv -e .env.local -- tsx tests/load/notification-processing-load-test.ts",
    "test:load:stripe-webhook-replay": "dotenv -e .env.local -- tsx tests/load/stripe-webhook-replay-load-test.ts",
    "test:privacy-phase1": "vitest run --config vitest.config.mts lib/security/contactNormalization.test.ts lib/security/crypto/hashLookup.test.ts lib/security/contactLookup.test.ts lib/security/crypto/aead.test.ts lib/security/addressEncryption.test.ts lib/security/auditRedaction.test.ts lib/admin/auditLog.test.ts lib/clientActions/idempotency.test.ts lib/clients/upsertProClient.test.ts lib/observability/authEvents.test.ts app/api/v1/auth/register/route.test.ts app/api/v1/auth/login/route.test.ts app/api/v1/auth/password-reset/request/route.test.ts app/api/v1/auth/phone/correct/route.test.ts",
    "test:privacy-export-delete": "vitest run --config vitest.config.mts lib/privacy/exportSafety.test.ts lib/privacy/exportUserData.test.ts lib/privacy/deleteUserData.test.ts lib/privacy/deleteUserDataSummary.test.ts app/api/internal/privacy/export/[userId]/route.test.ts app/api/internal/privacy/delete/[userId]/route.test.ts",
    "test:privacy": "pnpm test:privacy-phase1 && pnpm test:privacy-export-delete",
    "verify:privacy-phase1": "pnpm check:privacy-guards && pnpm test:privacy",
    "backfill:address-encryption": "tsx prisma/scripts/backfillAddressEncryption.ts",
    "backfill:notes-encryption": "tsx prisma/scripts/backfillNotesEncryption.ts",
    "backfill:phone-encryption": "tsx prisma/scripts/backfillPhoneEncryption.ts",
    "backfill:contact-hash-v2": "tsx prisma/scripts/backfillContactHashV2.ts",
    "backfill:email-encryption": "tsx prisma/scripts/backfillEmailEncryption.ts",
    "backfill:contact-hash-v2:test": "DATABASE_URL=postgresql://postgres:postgres@localhost:5433/tovis_test DIRECT_URL=postgresql://postgres:postgres@localhost:5433/tovis_test dotenv -e .env.local -- pnpm backfill:contact-hash-v2 -- --write",
    "backfill:contact-hash-v2:dev": "DATABASE_URL=postgresql://postgres:postgres@localhost:5434/tovis_dev DIRECT_URL=postgresql://postgres:postgres@localhost:5434/tovis_dev dotenv -e .env.local -- pnpm backfill:contact-hash-v2 -- --write",
    "seed:booking-overrides": "tsx prisma/seeds/bookingOverridePermissions.ts",
    "lookup:booking-override-ids": "tsx prisma/seeds/lookupBookingOverrideIds.ts",
    "jobs:looks-social:run-local": "node scripts/run-looks-social-jobs.mjs",
    "backfill:search-index": "tsx scripts/backfill-search-index.ts",
    "recompute:look-rank": "tsx scripts/recompute-look-rank-scores.ts",
    "backfill:look-embeddings": "tsx scripts/backfill-look-embeddings.ts",
    "backfill:portfolio-looks": "tsx scripts/backfill-portfolio-looks.ts",
    "import:license-permissions": "tsx scripts/importLicensePermissions.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.109.1",
    "@next/env": "16.2.6",
    "@prisma/client": "^6.19.0",
    "@radix-ui/react-select": "^2.2.6",
    "@sentry/nextjs": "^10.48.0",
    "@stripe/react-stripe-js": "^6.7.0",
    "@stripe/stripe-js": "^9.9.0",
    "@supabase/supabase-js": "^2.90.1",
    "@upstash/redis": "^1.36.1",
    "@vercel/functions": "^3.4.3",
    "apns2": "^12.2.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "framer-motion": "^12.29.2",
    "google-auth-library": "^10.9.0",
    "jsonwebtoken": "^9.0.2",
    "leaflet": "^1.9.4",
    "libphonenumber-js": "^1.12.41",
    "lucide-react": "^0.562.0",
    "next": "^16.2.6",
    "node-ical": "^0.26.1",
    "papaparse": "^5.5.3",
    "pdf-lib": "^1.17.1",
    "prisma": "^6.19.0",
    "qrcode": "^1.5.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-leaflet": "^5.0.0",
    "stripe": "^22.1.0",
    "tailwind-merge": "^3.4.0",
    "twilio": "^5.12.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@tailwindcss/cli": "^4.1.18",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.23",
    "depcheck": "^1.4.7",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.7",
    "jsdom": "^25.0.1",
    "madge": "^8.0.0",
    "postcss": "^8.5.10",
    "stylelint": "^16.26.1",
    "stylelint-config-tailwindcss": "^1.0.0",
    "tailwindcss": "^4.1.18",
    "ts-json-schema-generator": "^2.9.0",
    "ts-morph": "^27.0.2",
    "ts-node": "^10.9.2",
    "ts-prune": "^0.10.3",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "pnpm": {
    "overrides": {
      "axios@>=1.0.0 <1.18.0": "^1.18.0",
      "brace-expansion@<1.1.16": "^1.1.16",
      "brace-expansion@>=2.0.0 <2.1.2": "^2.1.2",
      "brace-expansion@>=3.0.0 <5.0.7": "^5.0.7",
      "js-yaml@>=3.0.0 <3.15.0": "^3.15.0",
      "js-yaml@>=4.0.0 <4.3.0": "^4.3.0",
      "defu@<=6.1.4": "^6.1.5",
      "esbuild@>=0.17.0 <0.28.1": "^0.28.1",
      "flatted@<3.4.2": "^3.4.2",
      "form-data@>=4.0.0 <4.0.6": "^4.0.6",
      "lodash@<=4.17.23": "^4.18.0",
      "effect@<3.20.0": "^3.20.0",
      "fast-uri@<3.1.3": "^3.1.3",
      "follow-redirects@<=1.15.11": "^1.16.0",
      "picomatch@<2.3.2": "^2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "^4.0.4",
      "postcss@<8.5.10": "^8.5.10",
      "qs@>=6.11.1 <6.15.2": "^6.15.2",
      "vite@>=7.0.0 <7.3.2": "^7.3.2",
      "ws@>=8.0.0 <8.20.1": "^8.20.1",
      "yaml@>=1.0.0 <1.10.3": "^1.10.3",
      "@opentelemetry/core@<2.8.0": "^2.8.0",
      "sharp@<0.35.0": "^0.35.0",
      "@babel/core@<=7.29.0": "^7.29.6"
