{
  "name": "tovis-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "typecheck": "tsc --noEmit",
    "seed": "node prisma/seed.cjs",
    "test": "vitest run --config vitest.config.mts",
    "test:watch": "vitest --config vitest.config.mts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:install": "playwright install --with-deps",
    "test:e2e:ci": "playwright test",
    "db:test:up": "docker run --name tovis-test-postgres -e POSTGRES_PASSWORD=postgres -e POSTGRES_USER=postgres -e POSTGRES_DB=tovis_test -p 5433:5432 -d postgres:16",
    "db:test:start": "docker start tovis-test-postgres",
    "db:test:stop": "docker stop tovis-test-postgres",
    "db:test:down": "docker rm -f tovis-test-postgres",
    "db:test:push": "node scripts/with-test-db.mjs npx prisma db push --skip-generate",
    "test:integration": "node scripts/with-test-db.mjs npx vitest run --config vitest.integration.config.mts",
    "test:load:signup": "tsx tests/load/signup-load-test.ts",
    "check:booking-boundary": "node tools/check-booking-write-boundary.mjs",
    "seed:booking-overrides": "tsx prisma/seeds/bookingOverridePermissions.ts",
    "lookup:booking-override-ids": "tsx prisma/seeds/lookupBookingOverrideIds.ts",
    "jobs:looks-social:run-local": "node scripts/run-looks-social-jobs.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@radix-ui/react-select": "^2.2.6",
    "@sentry/nextjs": "^10.48.0",
    "@supabase/supabase-js": "^2.90.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.1",
    "@vercel/functions": "^3.4.3",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "framer-motion": "^12.29.2",
    "jsonwebtoken": "^9.0.2",
    "leaflet": "^1.9.4",
    "libphonenumber-js": "^1.12.41",
    "lucide-react": "^0.562.0",
    "next": "^16.1.1",
    "prisma": "^6.19.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-leaflet": "^5.0.0",
    "tailwind-merge": "^3.4.0",
    "twilio": "^5.12.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@tailwindcss/cli": "^4.1.18",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.23",
    "depcheck": "^1.4.7",
    "eslint": "^9",
    "eslint-config-next": "16.0.7",
    "jsdom": "^25.0.1",
    "madge": "^8.0.0",
    "postcss": "^8.5.6",
    "stylelint": "^16.26.1",
    "stylelint-config-tailwindcss": "^1.0.0",
    "tailwindcss": "^4.1.18",
    "ts-morph": "^27.0.2",
    "ts-node": "^10.9.2",
    "ts-prune": "^0.10.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
